@model List<DairyProductApp.Models.ActivityLog>
@{ ViewData["Title"] = "Activity Log"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-clock-history me-2 text-info"></i>Activity Log</h3>
        <p class="text-muted mb-0 small">Kisne kya kiya - sabka record</p>
    </div>
    <a asp-action="Users" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Users</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="font-size:0.88rem;">
                <thead class="table-light">
                    <tr><th>Time</th><th>User</th><th>Action</th><th>Details</th></tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var log in Model)
                        {
                            var actionColor = log.Action switch
                            {
                                "Login" => "success",
                                "Logout" => "secondary",
                                "User Created" => "primary",
                                "User Deleted" => "danger",
                                "Password Changed" => "warning",
                                _ => "info"
                            };
                            <tr>
                                <td>
                                    <small>@log.Timestamp.ToString("dd/MM/yy")</small>
                                    <small class="text-muted d-block">@log.Timestamp.ToString("HH:mm:ss")</small>
                                </td>
                                <td class="fw-semibold">@log.Username</td>
                                <td><span class="badge bg-@actionColor">@log.Action</span></td>
                                <td class="text-muted">@log.Details</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4">Koi activity nahi hai</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
