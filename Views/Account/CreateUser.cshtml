@model DairyProductApp.Models.AdminUser
@{ ViewData["Title"] = "Add User"; }

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold text-primary mb-0"><i class="bi bi-person-plus me-2"></i>Add New User</h3>
            <a asp-action="Users" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
        </div>

        @if (ViewBag.Error != null)
        { <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.Error</div> }

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="CreateUser" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label fw-semibold"></label>
                            <input asp-for="FullName" class="form-control" placeholder="Full name">
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Mobile" class="form-label fw-semibold"></label>
                            <input asp-for="Mobile" class="form-control" placeholder="Mobile number">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Username" class="form-label fw-semibold"></label>
                            <input asp-for="Username" class="form-control" placeholder="Login username">
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label fw-semibold"></label>
                            <input asp-for="Password" class="form-control" placeholder="Login password">
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DairyName" class="form-label fw-semibold"></label>
                            <input asp-for="DairyName" class="form-control" placeholder="e.g. Raj Dairy Branch 2">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Role" class="form-label fw-semibold"></label>
                            <select asp-for="Role" asp-items="Html.GetEnumSelectList<DairyProductApp.Models.AdminRole>()" class="form-select"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IsActive" class="form-label fw-semibold d-block"></label>
                            <div class="form-check form-switch mt-2">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" checked>
                                <label class="form-check-label">Active</label>
                            </div>
                        </div>
                    </div>
                    <div class="alert alert-info mt-3 small">
                        <i class="bi bi-info-circle me-1"></i>
                        <strong>Roles:</strong><br>
                        <strong>Super Admin</strong> - Sab kuch manage, users banaye/delete kare, activity log dekhe<br>
                        <strong>Admin</strong> - Dairy manage kare, milk collection, orders, payments - users manage nahi<br>
                        <strong>Operator</strong> - Sirf milk collection aur basic entry kare
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-check-circle me-1"></i>Create User</button>
                        <a asp-action="Users" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
