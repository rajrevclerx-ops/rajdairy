@{
    ViewData["Title"] = "Admin Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Raj Dairy - Admin Login</title>
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0f172a" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { font-family: 'Inter', sans-serif; }
        body { background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 1rem; }
        .login-card { max-width: 440px; width: 100%; animation: slideUp 0.5s ease; }
        .glass-card { background: rgba(255,255,255,0.97); backdrop-filter: blur(20px); border-radius: 24px; border: 1px solid rgba(255,255,255,0.2); }
        .brand-icon { width: 80px; height: 80px; border-radius: 20px; background: linear-gradient(135deg, #0f172a, #334155); display: flex; align-items: center; justify-content: center; margin: 0 auto; box-shadow: 0 8px 32px rgba(15,23,42,0.4); }
        .input-modern { border-radius: 12px !important; border: 2px solid #e2e8f0; padding: 12px 16px; transition: all 0.3s; }
        .input-modern:focus { border-color: #0f172a; box-shadow: 0 0 0 4px rgba(15,23,42,0.08); }
        .btn-modern { border-radius: 12px; padding: 13px; font-weight: 600; font-size: 1rem; background: linear-gradient(135deg, #0f172a, #334155); border: none; transition: all 0.3s; }
        .btn-modern:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(15,23,42,0.3); background: linear-gradient(135deg, #1e293b, #475569); }
        .pro-badge { background: linear-gradient(135deg, #f59e0b, #ef4444); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 800; font-size: 0.75rem; }
        @@keyframes slideUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="glass-card shadow-lg">
            <div class="p-4 p-md-5">
                <div class="text-center mb-4">
                    <div class="brand-icon mb-3">
                        <i class="bi bi-droplet-fill text-white" style="font-size: 2.2rem;"></i>
                    </div>
                    <h3 class="fw-800 mb-0" style="color:#0f172a;">Raj Dairy <span class="pro-badge">PRO</span></h3>
                    <p class="text-muted mb-0" style="font-size:0.85rem;">Admin Panel - Secure Login</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert small py-2 text-center" style="border-radius:12px;border:none;background:rgba(239,68,68,0.1);color:#dc2626;">
                        <i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.Error
                    </div>
                }
                @if (TempData["Success"] != null)
                {
                    <div class="alert small py-2 text-center" style="border-radius:12px;border:none;background:rgba(34,197,94,0.1);color:#16a34a;">
                        <i class="bi bi-check-circle me-1"></i>@TempData["Success"]
                    </div>
                }

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-600 small text-muted">USERNAME</label>
                        <div class="input-group">
                            <span class="input-group-text" style="border-radius:12px 0 0 12px;border:2px solid #e2e8f0;border-right:0;background:#f8fafc;"><i class="bi bi-person"></i></span>
                            <input type="text" name="username" class="form-control input-modern" style="border-left:0;border-radius:0 12px 12px 0;" placeholder="Username" required autofocus>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-600 small text-muted">PASSWORD</label>
                        <div class="input-group">
                            <span class="input-group-text" style="border-radius:12px 0 0 12px;border:2px solid #e2e8f0;border-right:0;background:#f8fafc;"><i class="bi bi-lock"></i></span>
                            <input type="password" name="password" id="pwd" class="form-control input-modern" style="border-left:0;border-radius:0 12px 12px 0;" placeholder="Password" required>
                            <button type="button" class="input-group-text" style="border-radius:0 12px 12px 0;border:2px solid #e2e8f0;border-left:0;background:#f8fafc;cursor:pointer;" onclick="var p=document.getElementById('pwd');p.type=p.type==='password'?'text':'password';this.innerHTML=p.type==='password'?'<i class=\'bi bi-eye\'></i>':'<i class=\'bi bi-eye-slash\'></i>';">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-dark btn-modern w-100 mb-3">
                        <i class="bi bi-shield-lock me-2"></i>Login to Admin Panel
                    </button>
                </form>

                <div class="text-center">
                    <a href="/Public/Login" class="text-decoration-none" style="color:#2563eb;font-size:0.88rem;">
                        <i class="bi bi-person-badge me-1"></i>Partner Portal
                    </a>
                    <span class="text-muted mx-2">|</span>
                    <a href="/Public/TrackOrder" class="text-decoration-none" style="color:#2563eb;font-size:0.88rem;">
                        <i class="bi bi-truck me-1"></i>Track Order
                    </a>
                </div>
            </div>
        </div>
        <div class="text-center mt-3">
            <small class="text-white" style="opacity:0.3;"><i class="bi bi-shield-check me-1"></i>Encrypted & Secure</small>
        </div>
    </div>

    <script>if ('serviceWorker' in navigator) { navigator.serviceWorker.register('/sw.js'); }</script>
</body>
</html>
