@{
    ViewData["Title"] = "Logged Out";
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center p-5">
                <div class="mx-auto mb-4" style="width:80px;height:80px;border-radius:50%;background:rgba(40,167,69,0.1);display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-check-circle-fill text-success" style="font-size:2.5rem;"></i>
                </div>
                <h3 class="fw-bold mb-2">Successfully Logged Out!</h3>
                <p class="text-muted mb-4">Aap Raj Dairy se logout ho chuke hain. OAuth token delete ho gaya hai.</p>
                <div class="alert alert-info small text-start">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>Dobara login karne ke liye:</strong><br>
                    Terminal mein <code>dotnet run</code> se app restart karein. Browser mein Google login page khulega.
                </div>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg mt-2">
                    <i class="bi bi-house me-2"></i>Go to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
