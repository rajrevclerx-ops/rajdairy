@{
    ViewData["Title"] = "Admin Profile";
    var profilePhoto = ViewBag.ProfilePhoto as string;
    var hasPhoto = !string.IsNullOrEmpty(profilePhoto);
}

<div class="d-flex justify-content-between align-items-center mb-4 page-header">
    <div>
        <h3 class="fw-bold mb-1"><i class="bi bi-person-circle me-2 text-primary"></i>Admin Profile</h3>
        <p class="text-muted mb-0 small">Aapki profile aur dairy ka summary</p>
    </div>
</div>

<!-- Profile Card -->
<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center p-4">

                <!-- Profile Photo Section -->
                <div class="position-relative d-inline-block mb-3">
                    @if (hasPhoto)
                    {
                        <img src="@Html.Raw(profilePhoto)" alt="Admin Photo"
                             class="rounded-circle shadow"
                             style="width:120px;height:120px;object-fit:cover;border:4px solid #2e86c1;" />
                    }
                    else
                    {
                        <div class="rounded-circle shadow mx-auto"
                             style="width:120px;height:120px;background:linear-gradient(135deg,#1a5276,#2e86c1);display:flex;align-items:center;justify-content:center;border:4px solid rgba(255,255,255,0.3);">
                            <i class="bi bi-person-fill text-white" style="font-size:3.5rem;"></i>
                        </div>
                    }
                    <!-- Camera icon overlay -->
                    <label for="photoInput" class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow"
                           style="width:36px;height:36px;cursor:pointer;border:3px solid #fff;" title="Photo Upload/Change karein">
                        <i class="bi bi-camera-fill"></i>
                    </label>
                </div>

                <!-- Photo Upload Form (hidden file input) -->
                <form asp-action="UploadPhoto" method="post" enctype="multipart/form-data" id="photoForm">
                    @Html.AntiForgeryToken()
                    <input type="file" name="photo" id="photoInput" accept="image/*" class="d-none"
                           onchange="document.getElementById('photoForm').submit();" />
                </form>

                <!-- Photo action buttons -->
                <div class="mb-2">
                    <label for="photoInput" class="btn btn-sm btn-outline-primary me-1" style="cursor:pointer;">
                        <i class="bi bi-cloud-arrow-up me-1"></i>@(hasPhoto ? "Change Photo" : "Upload Photo")
                    </label>
                    @if (hasPhoto)
                    {
                        <form asp-action="RemovePhoto" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Photo remove karni hai?');">
                                <i class="bi bi-trash me-1"></i>Remove
                            </button>
                        </form>
                    }
                </div>
                <small class="text-muted d-block mb-2">JPG, PNG, GIF - Max 5MB</small>

                <h4 class="fw-bold mb-1">Admin</h4>
                <p class="text-muted mb-2">rajrevclerx&#64;gmail.com</p>
                <span class="badge bg-success px-3 py-2"><i class="bi bi-check-circle me-1"></i>Active</span>
                <hr class="my-3">
                <div class="text-start">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted"><i class="bi bi-building me-2"></i>Dairy Name</span>
                        <span class="fw-semibold">Raj Dairy</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted"><i class="bi bi-person-badge me-2"></i>Role</span>
                        <span class="fw-semibold">Administrator</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted"><i class="bi bi-calendar-check me-2"></i>Member Since</span>
                        <span class="fw-semibold">April 2026</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted"><i class="bi bi-database me-2"></i>Storage</span>
                        <span class="fw-semibold">Google Sheets</span>
                    </div>
                </div>
                <hr class="my-3">
                <div class="d-grid gap-2">
                    <a asp-action="Settings" class="btn btn-outline-primary"><i class="bi bi-gear me-1"></i>Settings</a>
                    <form asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger w-100"><i class="bi bi-box-arrow-right me-1"></i>Logout</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="col-lg-8">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm" style="border-left:4px solid #3498db !important;">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <p class="text-muted small mb-1">Total Collections</p>
                                <h3 class="fw-bold mb-0">@ViewBag.TotalCollections</h3>
                            </div>
                            <div class="stat-icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-cup-hot-fill"></i></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm" style="border-left:4px solid #27ae60 !important;">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <p class="text-muted small mb-1">Total Farmers</p>
                                <h3 class="fw-bold mb-0">@ViewBag.TotalFarmers</h3>
                            </div>
                            <div class="stat-icon bg-success bg-opacity-10 text-success"><i class="bi bi-people-fill"></i></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm" style="border-left:4px solid #8e44ad !important;">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <p class="text-muted small mb-1">Total Products</p>
                                <h3 class="fw-bold mb-0">@ViewBag.TotalProducts</h3>
                            </div>
                            <div class="stat-icon" style="background:rgba(142,68,173,0.1);color:#8e44ad;"><i class="bi bi-box-seam-fill"></i></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm" style="border-left:4px solid #e67e22 !important;">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <p class="text-muted small mb-1">Ghee Batches</p>
                                <h3 class="fw-bold mb-0">@ViewBag.TotalGhee</h3>
                            </div>
                            <div class="stat-icon bg-warning bg-opacity-10 text-warning"><i class="bi bi-fire"></i></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm" style="border-left:4px solid #e74c3c !important;">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <p class="text-muted small mb-1">Rate Slabs</p>
                                <h3 class="fw-bold mb-0">@ViewBag.TotalRates</h3>
                            </div>
                            <div class="stat-icon bg-danger bg-opacity-10 text-danger"><i class="bi bi-currency-rupee"></i></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm" style="border-left:4px solid #1abc9c !important;">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <p class="text-muted small mb-1">Ghee Stock</p>
                                <h3 class="fw-bold mb-0">@(((decimal)ViewBag.TotalGheeStock).ToString("F1")) Kg</h3>
                            </div>
                            <div class="stat-icon" style="background:rgba(26,188,156,0.1);color:#1abc9c;"><i class="bi bi-graph-up"></i></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Revenue Summary -->
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-header bg-white border-0">
                <h6 class="fw-bold mb-0"><i class="bi bi-bar-chart-fill text-primary me-2"></i>Overall Summary</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4 text-center">
                        <div class="card bg-primary bg-opacity-10 border-0">
                            <div class="card-body py-3">
                                <small class="text-muted">Total Milk Collected</small>
                                <h4 class="fw-bold text-primary mb-0">@(((decimal)ViewBag.TotalMilk).ToString("F0")) L</h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 text-center">
                        <div class="card bg-success bg-opacity-10 border-0">
                            <div class="card-body py-3">
                                <small class="text-muted">Total Revenue</small>
                                <h4 class="fw-bold text-success mb-0">&#8377;@(((decimal)ViewBag.TotalRevenue).ToString("F0"))</h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 text-center">
                        <div class="card bg-warning bg-opacity-10 border-0">
                            <div class="card-body py-3">
                                <small class="text-muted">Ghee Stock Value</small>
                                <h4 class="fw-bold text-warning mb-0">@(((decimal)ViewBag.TotalGheeStock).ToString("F1")) Kg</h4>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
