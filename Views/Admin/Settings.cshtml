@{
    ViewData["Title"] = "Settings";
}

<div class="d-flex justify-content-between align-items-center mb-4 page-header">
    <div>
        <h3 class="fw-bold mb-1"><i class="bi bi-gear me-2 text-primary"></i>Settings</h3>
        <p class="text-muted mb-0 small">App settings aur configurations manage karein</p>
    </div>
</div>

<div class="row g-4">
    <!-- App Info -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0">
                <h6 class="fw-bold mb-0"><i class="bi bi-info-circle text-primary me-2"></i>Application Info</h6>
            </div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr>
                        <td class="text-muted" style="width:40%;"><i class="bi bi-app me-2"></i>App Name</td>
                        <td class="fw-semibold">Raj Dairy</td>
                    </tr>
                    <tr>
                        <td class="text-muted"><i class="bi bi-code-slash me-2"></i>Version</td>
                        <td class="fw-semibold">1.0.0</td>
                    </tr>
                    <tr>
                        <td class="text-muted"><i class="bi bi-gear me-2"></i>Framework</td>
                        <td class="fw-semibold">.NET 9.0 MVC</td>
                    </tr>
                    <tr>
                        <td class="text-muted"><i class="bi bi-database me-2"></i>Database</td>
                        <td class="fw-semibold">Google Sheets API</td>
                    </tr>
                    <tr>
                        <td class="text-muted"><i class="bi bi-link-45deg me-2"></i>Sheet ID</td>
                        <td class="fw-semibold text-break small">1wA0Vf1Lb-vwVLCogZni1DmUveMV5Hh2W4erGs0qFF2s</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <!-- Data Status -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0">
                <h6 class="fw-bold mb-0"><i class="bi bi-clipboard-data text-success me-2"></i>Data Status</h6>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="small fw-semibold">Active Rates</span>
                        <span class="badge bg-success">@ViewBag.ActiveRates active</span>
                    </div>
                    <div class="progress" style="height:8px;">
                        @{
                            int totalRates = (int)ViewBag.ActiveRates + (int)ViewBag.InactiveRates;
                            int ratePercent = totalRates > 0 ? ((int)ViewBag.ActiveRates * 100 / totalRates) : 0;
                        }
                        <div class="progress-bar bg-success" style="width:@(ratePercent)%"></div>
                    </div>
                    <small class="text-muted">@ViewBag.InactiveRates inactive</small>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="small fw-semibold">Active Products</span>
                        <span class="badge bg-primary">@ViewBag.ActiveProducts active</span>
                    </div>
                    <div class="progress" style="height:8px;">
                        @{
                            int totalProducts = (int)ViewBag.ActiveProducts + (int)ViewBag.InactiveProducts;
                            int productPercent = totalProducts > 0 ? ((int)ViewBag.ActiveProducts * 100 / totalProducts) : 0;
                        }
                        <div class="progress-bar bg-primary" style="width:@(productPercent)%"></div>
                    </div>
                    <small class="text-muted">@ViewBag.InactiveProducts inactive</small>
                </div>
                <div class="mb-0">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="small fw-semibold">Expired Products</span>
                        <span class="badge bg-danger">@ViewBag.ExpiredProducts expired</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0">
                <h6 class="fw-bold mb-0"><i class="bi bi-lightning-fill text-warning me-2"></i>Quick Actions</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-controller="MilkRate" asp-action="Create" class="btn btn-outline-primary text-start">
                        <i class="bi bi-plus-circle me-2"></i>Add New Milk Rate
                    </a>
                    <a asp-controller="DairyProduct" asp-action="Create" class="btn btn-outline-success text-start">
                        <i class="bi bi-plus-circle me-2"></i>Add New Product
                    </a>
                    <a asp-controller="GheeProduct" asp-action="Create" class="btn btn-outline-warning text-start">
                        <i class="bi bi-plus-circle me-2"></i>Add New Ghee Batch
                    </a>
                    <a asp-controller="MilkCollection" asp-action="Create" class="btn btn-outline-info text-start">
                        <i class="bi bi-plus-circle me-2"></i>New Milk Collection
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Google Sheet Link -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0">
                <h6 class="fw-bold mb-0"><i class="bi bi-table text-success me-2"></i>Google Sheet</h6>
            </div>
            <div class="card-body">
                <p class="text-muted small">Aapka saara data is Google Sheet mein store hai. Direct access ke liye neeche click karein:</p>
                <a href="https://docs.google.com/spreadsheets/d/1wA0Vf1Lb-vwVLCogZni1DmUveMV5Hh2W4erGs0qFF2s/edit" target="_blank" class="btn btn-success w-100 mb-3">
                    <i class="bi bi-box-arrow-up-right me-2"></i>Open Google Sheet
                </a>
                <div class="alert alert-info small mb-0">
                    <i class="bi bi-info-circle me-2"></i>Sheet mein 4 tabs hain: MilkCollection, MilkRates, DairyProducts, GheeProducts
                </div>
            </div>
        </div>
    </div>

    <!-- Logout Section -->
    <div class="col-12">
        <div class="card border-0 shadow-sm border-danger">
            <div class="card-header bg-white border-0">
                <h6 class="fw-bold mb-0 text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Danger Zone</h6>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="fw-bold mb-1">Logout from Raj Dairy</h6>
                        <p class="text-muted small mb-0">Google OAuth token delete ho jayega. Agla run pe phir se login karna hoga.</p>
                    </div>
                    <form asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Kya aap sure hain ki logout karna hai?');">
                            <i class="bi bi-box-arrow-right me-1"></i>Logout
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
