@{
    ViewData["Title"] = "Settings";
}

<div class="d-flex justify-content-between align-items-center mb-4 page-header">
    <div>
        <h3 class="fw-bold mb-1"><i class="bi bi-gear me-2 text-primary"></i>Settings</h3>
        <p class="text-muted mb-0 small">App settings aur configurations manage karein</p>
    </div>
</div>

<div class="row g-4">
    <!-- App Info -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0">
                <h6 class="fw-bold mb-0"><i class="bi bi-info-circle text-primary me-2"></i>Application Info</h6>
            </div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr>
                        <td class="text-muted" style="width:40%;"><i class="bi bi-app me-2"></i>App Name</td>
                        <td class="fw-semibold">Raj Dairy</td>
                    </tr>
                    <tr>
                        <td class="text-muted"><i class="bi bi-code-slash me-2"></i>Version</td>
                        <td class="fw-semibold">1.0.0</td>
                    </tr>
                    <tr>
                        <td class="text-muted"><i class="bi bi-gear me-2"></i>Framework</td>
                        <td class="fw-semibold">.NET 9.0 MVC</td>
                    </tr>
                    <tr>
                        <td class="text-muted"><i class="bi bi-database me-2"></i>Database</td>
                        <td class="fw-semibold">Google Sheets API</td>
                    </tr>
                    <tr>
                        <td class="text-muted"><i class="bi bi-link-45deg me-2"></i>Sheet ID</td>
                        <td class="fw-semibold text-break small">1wA0Vf1Lb-vwVLCogZni1DmUveMV5Hh2W4erGs0qFF2s</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <!-- Data Status -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0">
                <h6 class="fw-bold mb-0"><i class="bi bi-clipboard-data text-success me-2"></i>Data Status</h6>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="small fw-semibold">Active Rates</span>
                        <span class="badge bg-success">@ViewBag.ActiveRates active</span>
                    </div>
                    <div class="progress" style="height:8px;">
                        @{
                            int totalRates = (int)ViewBag.ActiveRates + (int)ViewBag.InactiveRates;
                            int ratePercent = totalRates > 0 ? ((int)ViewBag.ActiveRates * 100 / totalRates) : 0;
                        }
                        <div class="progress-bar bg-success" style="width:@(ratePercent)%"></div>
                    </div>
                    <small class="text-muted">@ViewBag.InactiveRates inactive</small>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="small fw-semibold">Active Products</span>
                        <span class="badge bg-primary">@ViewBag.ActiveProducts active</span>
                    </div>
                    <div class="progress" style="height:8px;">
                        @{
                            int totalProducts = (int)ViewBag.ActiveProducts + (int)ViewBag.InactiveProducts;
                            int productPercent = totalProducts > 0 ? ((int)ViewBag.ActiveProducts * 100 / totalProducts) : 0;
                        }
                        <div class="progress-bar bg-primary" style="width:@(productPercent)%"></div>
                    </div>
                    <small class="text-muted">@ViewBag.InactiveProducts inactive</small>
                </div>
                <div class="mb-0">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="small fw-semibold">Expired Products</span>
                        <span class="badge bg-danger">@ViewBag.ExpiredProducts expired</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Payment QR Code & UPI -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0">
                <h6 class="fw-bold mb-0"><i class="bi bi-qr-code text-primary me-2"></i>Payment QR Code</h6>
            </div>
            <div class="card-body text-center">
                @{var qrCode = ViewBag.QrCode as string;}
                @if (!string.IsNullOrEmpty(qrCode))
                {
                    <img src="@Html.Raw(qrCode)" alt="QR Code" class="img-fluid rounded shadow-sm mb-3" style="max-width:200px;" />
                    <form asp-action="RemoveQr" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash me-1"></i>Remove QR</button>
                    </form>
                }
                else
                {
                    <div class="py-3 text-muted"><i class="bi bi-qr-code fs-1 d-block mb-2"></i>Koi QR Code nahi hai</div>
                }
                <hr>
                <form asp-action="UploadQr" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="input-group">
                        <input type="file" name="qrImage" class="form-control" accept="image/*" required>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-upload me-1"></i>Upload</button>
                    </div>
                    <small class="text-muted">Payment QR code ki photo upload karein (JPG/PNG)</small>
                </form>
            </div>
        </div>
    </div>

    <!-- UPI ID -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0">
                <h6 class="fw-bold mb-0"><i class="bi bi-credit-card text-success me-2"></i>UPI Payment Details</h6>
            </div>
            <div class="card-body">
                <form asp-action="SaveUpi" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">UPI ID</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-at"></i></span>
                            <input type="text" name="upiId" class="form-control" value="@ViewBag.UpiId" placeholder="e.g. rajdairy@upi">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">UPI Display Name</label>
                        <input type="text" name="upiName" class="form-control" value="@ViewBag.UpiName" placeholder="e.g. Raj Dairy">
                    </div>
                    <button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-1"></i>Save UPI Details</button>
                </form>
                @if (!string.IsNullOrEmpty(ViewBag.UpiId as string))
                {
                    <hr>
                    <div class="alert alert-success small mb-0">
                        <i class="bi bi-check-circle me-1"></i>UPI Active: <strong>@ViewBag.UpiId</strong>
                        <br>Partners ko yeh payment link dikhai dega unke portal mein
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Security -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0">
                <h6 class="fw-bold mb-0"><i class="bi bi-shield-lock text-warning me-2"></i>Security</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-controller="Account" asp-action="ChangePassword" class="btn btn-outline-warning text-start">
                        <i class="bi bi-key me-2"></i>Change Username / Password
                    </a>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger text-start">
                        <i class="bi bi-box-arrow-right me-2"></i>Logout
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Google Sheet Link -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0">
                <h6 class="fw-bold mb-0"><i class="bi bi-table text-success me-2"></i>Google Sheet</h6>
            </div>
            <div class="card-body">
                <p class="text-muted small">Aapka saara data is Google Sheet mein store hai:</p>
                <a href="https://docs.google.com/spreadsheets/d/1wA0Vf1Lb-vwVLCogZni1DmUveMV5Hh2W4erGs0qFF2s/edit" target="_blank" class="btn btn-success w-100 mb-2">
                    <i class="bi bi-box-arrow-up-right me-2"></i>Open Google Sheet
                </a>
            </div>
        </div>
    </div>
</div>
