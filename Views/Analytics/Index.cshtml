@model DairyProductApp.Models.AnalyticsViewModel
@{
    ViewData["Title"] = "Analytics";
}

<div class="d-flex justify-content-between align-items-center mb-4 page-header">
    <div>
        <h3 class="fw-bold mb-1"><i class="bi bi-graph-up-arrow me-2 text-primary"></i>Analytics Dashboard</h3>
        <p class="text-muted mb-0 small">Detailed business insights aur performance metrics</p>
    </div>
</div>

<!-- Summary Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="analytics-stat">
            <div class="stat-value text-primary">@Model.TotalMilkCollected.ToString("N0")</div>
            <div class="stat-label">Total Milk (Liters)</div>
            @if (Model.MilkGrowthPercent != 0)
            {
                <div class="mt-2">
                    <span class="stat-trend @(Model.MilkGrowthPercent >= 0 ? "up" : "down")">
                        <i class="bi @(Model.MilkGrowthPercent >= 0 ? "bi-arrow-up" : "bi-arrow-down")"></i>
                        @(Math.Abs(Model.MilkGrowthPercent).ToString("F1"))%
                    </span>
                    <small class="text-muted ms-1">vs last month</small>
                </div>
            }
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="analytics-stat">
            <div class="stat-value text-success">&#8377;@Model.TotalRevenueGenerated.ToString("N0")</div>
            <div class="stat-label">Total Revenue</div>
            @if (Model.RevenueGrowthPercent != 0)
            {
                <div class="mt-2">
                    <span class="stat-trend @(Model.RevenueGrowthPercent >= 0 ? "up" : "down")">
                        <i class="bi @(Model.RevenueGrowthPercent >= 0 ? "bi-arrow-up" : "bi-arrow-down")"></i>
                        @(Math.Abs(Model.RevenueGrowthPercent).ToString("F1"))%
                    </span>
                    <small class="text-muted ms-1">vs last month</small>
                </div>
            }
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="analytics-stat">
            <div class="stat-value" style="color:#7c3aed;">@Model.TotalGheeProduced.ToString("N1")</div>
            <div class="stat-label">Ghee Produced (Kg)</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="analytics-stat">
            <div class="stat-value text-info">@Model.AvgDailyMilk.ToString("N0")</div>
            <div class="stat-label">Avg Daily Milk (L)</div>
        </div>
    </div>
</div>

<!-- Quality Metrics -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-3 text-center">
                <h5 class="fw-bold text-danger mb-1">@Model.AvgFatPercent.ToString("F2")%</h5>
                <small class="text-muted">Avg Fat Percentage</small>
                <div class="progress mt-2">
                    <div class="progress-bar bg-danger" style="width:@((Model.AvgFatPercent / 10 * 100).ToString("F0"))%"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-3 text-center">
                <h5 class="fw-bold text-info mb-1">@Model.AvgSNFPercent.ToString("F2")%</h5>
                <small class="text-muted">Avg SNF Percentage</small>
                <div class="progress mt-2">
                    <div class="progress-bar bg-info" style="width:@((Model.AvgSNFPercent / 12 * 100).ToString("F0"))%"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-3 text-center">
                <h5 class="fw-bold text-primary mb-1">@Model.TotalTransactions</h5>
                <small class="text-muted">Total Transactions</small>
                <div class="progress mt-2">
                    <div class="progress-bar bg-primary" style="width:75%"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts -->
<div class="row g-3 mb-4">
    <div class="col-xl-8">
        <div class="card chart-card shadow-sm border-0">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold"><i class="bi bi-bar-chart-fill text-primary me-2"></i>Monthly Milk Collection & Revenue</h6>
            </div>
            <div class="card-body">
                <canvas id="monthlyChart" height="300"></canvas>
            </div>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="card chart-card shadow-sm border-0 h-100">
            <div class="card-header">
                <h6 class="mb-0 fw-bold"><i class="bi bi-fire text-warning me-2"></i>Monthly Ghee Production</h6>
            </div>
            <div class="card-body">
                <canvas id="gheeChart" height="300"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-xl-6">
        <div class="card chart-card shadow-sm border-0">
            <div class="card-header">
                <h6 class="mb-0 fw-bold"><i class="bi bi-graph-up text-success me-2"></i>Weekly Milk Trend</h6>
            </div>
            <div class="card-body">
                <canvas id="weeklyChart" height="250"></canvas>
            </div>
        </div>
    </div>
    <div class="col-xl-6">
        <div class="card chart-card shadow-sm border-0">
            <div class="card-header">
                <h6 class="mb-0 fw-bold"><i class="bi bi-pie-chart-fill me-2" style="color:#7c3aed;"></i>Product Transaction Distribution</h6>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="productChart" height="250"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Top Farmers -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0">
        <h6 class="mb-0 fw-bold"><i class="bi bi-trophy-fill text-warning me-2"></i>Top 10 Farmers - Milk Contribution</h6>
    </div>
    <div class="card-body p-0">
        @if (Model.TopFarmers.Any())
        {
            <div class="p-3">
                @for (int i = 0; i < Model.TopFarmers.Count; i++)
                {
                    var farmer = Model.TopFarmers[i];
                    var maxQty = Model.TopFarmers.First().TotalQuantity;
                    var widthPct = maxQty > 0 ? (farmer.TotalQuantity / maxQty * 100) : 0;
                    <div class="farmer-rank">
                        <div class="rank-number @(i >= 3 ? "bg-light text-muted" : "")">@(i + 1)</div>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="fw-semibold">@farmer.FarmerName</span>
                                <span class="fw-bold text-primary">@farmer.TotalQuantity.ToString("N0") L</span>
                            </div>
                            <div class="progress" style="height:6px;">
                                <div class="progress-bar" style="width:@widthPct.ToString("F0")%;background:linear-gradient(90deg,#2563eb,#3b82f6);"></div>
                            </div>
                            <div class="d-flex gap-3 mt-1">
                                <small class="text-muted">Fat: @farmer.AvgFat.ToString("F1")%</small>
                                <small class="text-muted">Entries: @farmer.TotalEntries</small>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state"><i class="bi bi-inbox"></i><p>Koi data nahi hai</p></div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // Monthly Chart
        const monthCtx = document.getElementById('monthlyChart').getContext('2d');
        new Chart(monthCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthLabels)),
                datasets: [{
                    label: 'Milk (Liters)',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyMilkData)),
                    backgroundColor: 'rgba(37,99,235,0.8)',
                    borderRadius: 8,
                    barThickness: 30
                }, {
                    label: 'Revenue (₹)',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenueData)),
                    backgroundColor: 'rgba(16,185,129,0.8)',
                    borderRadius: 8,
                    barThickness: 30,
                    yAxisID: 'y1'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'top', labels: { usePointStyle: true, font: { family: 'Inter', weight: '600' } } } },
                scales: {
                    y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.04)' } },
                    y1: { beginAtZero: true, position: 'right', grid: { display: false } },
                    x: { grid: { display: false } }
                }
            }
        });

        // Ghee Chart
        new Chart(document.getElementById('gheeChart').getContext('2d'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthLabels)),
                datasets: [{
                    label: 'Ghee (Kg)',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyGheeData)),
                    backgroundColor: 'rgba(245,158,11,0.8)',
                    borderRadius: 8,
                    barThickness: 25
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.04)' } }, x: { grid: { display: false } } }
            }
        });

        // Weekly Chart
        const weekGradient = document.getElementById('weeklyChart').getContext('2d').createLinearGradient(0, 0, 0, 250);
        weekGradient.addColorStop(0, 'rgba(16,185,129,0.3)');
        weekGradient.addColorStop(1, 'rgba(16,185,129,0.02)');
        new Chart(document.getElementById('weeklyChart').getContext('2d'), {
            type: 'line',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeekLabels)),
                datasets: [{
                    label: 'Milk (Liters)',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeeklyMilkData)),
                    borderColor: '#10b981',
                    backgroundColor: weekGradient,
                    fill: true,
                    tension: 0.4,
                    borderWidth: 3,
                    pointRadius: 6,
                    pointBackgroundColor: '#10b981',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.04)' } }, x: { grid: { display: false } } }
            }
        });

        // Product Chart
        const productColors = ['#2563eb', '#7c3aed', '#10b981', '#f59e0b', '#ef4444', '#06b6d4', '#ec4899', '#8b5cf6'];
        new Chart(document.getElementById('productChart').getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProductLabels)),
                datasets: [{
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProductData)),
                    backgroundColor: productColors.slice(0, @Model.ProductLabels.Count),
                    borderWidth: 0,
                    hoverOffset: 10
                }]
            },
            options: {
                responsive: true,
                cutout: '60%',
                plugins: {
                    legend: { position: 'right', labels: { usePointStyle: true, padding: 12, font: { family: 'Inter', size: 11 } } }
                }
            }
        });
    </script>
}
