@model DairyProductApp.Models.DairyProduct
@{
    ViewData["Title"] = "Add Dairy Product";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-success mb-0"><i class="bi bi-plus-circle me-2"></i>Add Dairy Product</h2>
                <p class="text-muted mb-0">Naya dairy product add karein</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ProductName" class="form-label fw-semibold"></label>
                            <input asp-for="ProductName" class="form-control" placeholder="Product ka naam">
                            <span asp-validation-for="ProductName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Category" class="form-label fw-semibold"></label>
                            <select asp-for="Category" asp-items="Html.GetEnumSelectList<DairyProductApp.Models.ProductCategory>()" class="form-select">
                                <option value="">-- Select --</option>
                            </select>
                            <span asp-validation-for="Category" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Quantity" class="form-label fw-semibold"></label>
                            <input asp-for="Quantity" class="form-control" step="0.01">
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Unit" class="form-label fw-semibold"></label>
                            <select asp-for="Unit" asp-items="Html.GetEnumSelectList<DairyProductApp.Models.ProductUnit>()" class="form-select"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Price" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">&#8377;</span>
                                <input asp-for="Price" class="form-control" step="0.01">
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StockQuantity" class="form-label fw-semibold"></label>
                            <input asp-for="StockQuantity" class="form-control" step="0.01">
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ManufacturingDate" class="form-label fw-semibold"></label>
                            <input asp-for="ManufacturingDate" class="form-control" type="date">
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ExpiryDate" class="form-label fw-semibold"></label>
                            <input asp-for="ExpiryDate" class="form-control" type="date">
                        </div>
                        <div class="col-md-8">
                            <label asp-for="Description" class="form-label fw-semibold"></label>
                            <input asp-for="Description" class="form-control" placeholder="Description (optional)">
                        </div>
                        <div class="col-md-4">
                            <label asp-for="IsActive" class="form-label fw-semibold d-block"></label>
                            <div class="form-check form-switch mt-2">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" checked>
                                <label class="form-check-label">Active</label>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-success btn-lg"><i class="bi bi-check-circle me-1"></i>Save Product</button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
