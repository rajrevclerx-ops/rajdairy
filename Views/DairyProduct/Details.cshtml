@model DairyProductApp.Models.DairyProduct
@{
    ViewData["Title"] = "Product Details";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-primary mb-0"><i class="bi bi-eye me-2"></i>Product Details</h2>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <span class="badge bg-info mb-2">@Model.Category</span>
                        <h3 class="fw-bold">@Model.ProductName</h3>
                    </div>
                    <h2 class="fw-bold text-success">&#8377;@Model.Price.ToString("F0")</h2>
                </div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="card bg-primary bg-opacity-10 border-0">
                            <div class="card-body text-center">
                                <small class="text-muted">Quantity</small>
                                <h5 class="fw-bold">@Model.Quantity @Model.Unit</h5>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-success bg-opacity-10 border-0">
                            <div class="card-body text-center">
                                <small class="text-muted">Stock</small>
                                <h5 class="fw-bold">@Model.StockQuantity.ToString("F0") @Model.Unit</h5>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-warning bg-opacity-10 border-0">
                            <div class="card-body text-center">
                                <small class="text-muted">Status</small>
                                <h5 class="fw-bold">@(Model.IsActive ? "Active" : "Inactive")</h5>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-1"><strong>Manufacturing Date:</strong> @Model.ManufacturingDate.ToString("dd MMM yyyy")</p>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-1"><strong>Expiry Date:</strong> @Model.ExpiryDate.ToString("dd MMM yyyy")
                            @if (Model.ExpiryDate < DateTime.Today) { <span class="badge bg-danger">Expired</span> }
                        </p>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="col-12">
                            <p><strong>Description:</strong> @Model.Description</p>
                        </div>
                    }
                </div>
                <div class="mt-4 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil me-1"></i>Edit</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</a>
                </div>
            </div>
        </div>
    </div>
</div>
