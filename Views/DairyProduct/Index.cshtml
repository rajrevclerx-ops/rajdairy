@model IEnumerable<DairyProductApp.Models.DairyProduct>
@{
    ViewData["Title"] = "Dairy Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-primary mb-0"><i class="bi bi-box-seam-fill me-2"></i>Dairy Products</h2>
        <p class="text-muted mb-0">Sabhi dairy products manage karein</p>
    </div>
    <a asp-action="Create" class="btn btn-success shadow-sm"><i class="bi bi-plus-circle me-1"></i>Add Product</a>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Search Product</label>
                <input type="text" name="search" class="form-control" value="@ViewBag.Search" placeholder="Product name...">
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Category</label>
                <select name="category" class="form-select">
                    <option value="">All Categories</option>
                    @foreach (var cat in Enum.GetValues<DairyProductApp.Models.ProductCategory>())
                    {
                        <option value="@cat" selected="@(ViewBag.Category?.ToString() == cat.ToString())">@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-search me-1"></i>Search</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-circle me-1"></i>Clear</a>
            </div>
        </form>
    </div>
</div>

<!-- Products Grid -->
<div class="row g-3">
    @if (Model.Any())
    {
        @foreach (var item in Model)
        {
            var categoryColor = item.Category switch
            {
                DairyProductApp.Models.ProductCategory.Milk => "primary",
                DairyProductApp.Models.ProductCategory.Curd => "info",
                DairyProductApp.Models.ProductCategory.Paneer => "warning",
                DairyProductApp.Models.ProductCategory.Butter => "warning",
                DairyProductApp.Models.ProductCategory.Ghee => "danger",
                DairyProductApp.Models.ProductCategory.Cream => "light",
                _ => "secondary"
            };
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge bg-@categoryColor">@item.Category</span>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </div>
                        <h5 class="fw-bold">@item.ProductName</h5>
                        <p class="text-muted small mb-2">@item.Quantity @item.Unit</p>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="fs-4 fw-bold text-success">&#8377;@item.Price.ToString("F0")</span>
                            <span class="text-muted small">Stock: @item.StockQuantity.ToString("F0") @item.Unit</span>
                        </div>
                        <div class="small text-muted mb-3">
                            <i class="bi bi-calendar me-1"></i>Mfg: @item.ManufacturingDate.ToString("dd/MM/yy") |
                            Exp: @item.ExpiryDate.ToString("dd/MM/yy")
                            @if (item.ExpiryDate < DateTime.Today)
                            {
                                <span class="badge bg-danger ms-1">Expired</span>
                            }
                            else if (item.ExpiryDate <= DateTime.Today.AddDays(3))
                            {
                                <span class="badge bg-warning text-dark ms-1">Expiring Soon</span>
                            }
                        </div>
                        <div class="btn-group w-100">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm"><i class="bi bi-eye me-1"></i>View</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <i class="bi bi-inbox fs-1 text-muted d-block mb-2"></i>
            <p class="text-muted">Koi product nahi mila. Naya product add karein!</p>
        </div>
    }
</div>
