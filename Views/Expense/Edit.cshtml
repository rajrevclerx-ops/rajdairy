@model DairyProductApp.Models.Expense
@{ ViewData["Title"] = "Edit Expense"; }

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold text-primary mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Expense</h3>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
        </div>
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Category" class="form-label fw-semibold"></label>
                            <select asp-for="Category" asp-items="Html.GetEnumSelectList<DairyProductApp.Models.ExpenseCategory>()" class="form-select"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Amount" class="form-label fw-semibold"></label>
                            <div class="input-group"><span class="input-group-text">&#8377;</span><input asp-for="Amount" class="form-control" step="0.01"></div>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-semibold"></label>
                            <input asp-for="Description" class="form-control">
                        </div>
                        <div class="col-md-4"><label asp-for="ExpenseDate" class="form-label fw-semibold"></label><input asp-for="ExpenseDate" class="form-control" type="date"></div>
                        <div class="col-md-4"><label asp-for="Mode" class="form-label fw-semibold"></label><select asp-for="Mode" asp-items="Html.GetEnumSelectList<DairyProductApp.Models.PaymentMode>()" class="form-select"></select></div>
                        <div class="col-md-4"><label asp-for="Remarks" class="form-label fw-semibold"></label><input asp-for="Remarks" class="form-control"></div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-check-circle me-1"></i>Update</button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
