@model List<DairyProductApp.Models.Expense>
@{ ViewData["Title"] = "Expenses"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-wallet2 me-2 text-danger"></i>Expenses</h3>
        <p class="text-muted mb-0 small">Sabhi kharchon ka record</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="ProfitLoss" class="btn btn-outline-success"><i class="bi bi-graph-up-arrow me-1"></i>P&L Report</a>
        <a asp-action="Create" class="btn btn-danger"><i class="bi bi-plus-circle me-1"></i>Add Expense</a>
    </div>
</div>

<!-- Date Filter -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-auto"><label class="form-label small mb-0 fw-semibold">From</label></div>
            <div class="col-auto"><input type="date" name="from" class="form-control form-control-sm" value="@ViewBag.From"></div>
            <div class="col-auto"><label class="form-label small mb-0 fw-semibold">To</label></div>
            <div class="col-auto"><input type="date" name="to" class="form-control form-control-sm" value="@ViewBag.To"></div>
            <div class="col-auto"><button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-filter me-1"></i>Filter</button></div>
            <div class="col-auto ms-auto">
                <span class="badge bg-danger fs-6">Total: &#8377;@(((decimal)ViewBag.TotalExpenses).ToString("N0"))</span>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr><th>Date</th><th>Category</th><th>Description</th><th>Amount</th><th>Mode</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var e in Model)
                        {
                            <tr>
                                <td>@e.ExpenseDate.ToString("dd/MM/yy")</td>
                                <td><span class="badge bg-danger bg-opacity-75">@e.Category</span></td>
                                <td>@e.Description</td>
                                <td class="fw-bold text-danger">&#8377;@e.Amount.ToString("N0")</td>
                                <td><span class="badge bg-secondary">@e.Mode</span></td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                    <form asp-action="Delete" asp-route-id="@e.Id" method="post" class="d-inline" onsubmit="return confirm('Delete?');">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">Koi expense nahi hai</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
