@model DairyProductApp.Models.GheeProduct
@{
    ViewData["Title"] = "Ghee Batch Details";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-primary mb-0"><i class="bi bi-eye me-2"></i>Ghee Batch Details</h2>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h3 class="fw-bold">Batch: @Model.BatchNumber</h3>
                        <span class="badge bg-info me-1">@Model.GheeType</span>
                        <span class="badge bg-warning">@Model.Quality</span>
                    </div>
                    <h2 class="fw-bold text-success">&#8377;@Model.TotalValue.ToString("F0")</h2>
                </div>

                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="card bg-primary bg-opacity-10 border-0">
                            <div class="card-body text-center">
                                <small class="text-muted">Milk Used</small>
                                <h4 class="fw-bold text-primary">@Model.MilkUsedLiters.ToString("F0") L</h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-warning bg-opacity-10 border-0">
                            <div class="card-body text-center">
                                <small class="text-muted">Ghee Produced</small>
                                <h4 class="fw-bold text-warning">@Model.GheeProducedKg.ToString("F1") Kg</h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-success bg-opacity-10 border-0">
                            <div class="card-body text-center">
                                <small class="text-muted">Yield Rate</small>
                                <h4 class="fw-bold text-success">@Model.YieldRate.ToString("F1")%</h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-danger bg-opacity-10 border-0">
                            <div class="card-body text-center">
                                <small class="text-muted">Price/Kg</small>
                                <h4 class="fw-bold text-danger">&#8377;@Model.PricePerKg.ToString("F0")</h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <p><strong>Stock Available:</strong> @Model.StockKg.ToString("F1") Kg</p>
                    </div>
                    <div class="col-md-4">
                        <p><strong>Production Date:</strong> @Model.ProductionDate.ToString("dd MMM yyyy")</p>
                    </div>
                    <div class="col-md-4">
                        <p><strong>Expiry Date:</strong> @Model.ExpiryDate.ToString("dd MMM yyyy")</p>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="col-12">
                            <p><strong>Description:</strong> @Model.Description</p>
                        </div>
                    }
                </div>
                <div class="mt-4 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil me-1"></i>Edit</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</a>
                </div>
            </div>
        </div>
    </div>
</div>
