@model DairyProductApp.Models.GheeProduct
@{
    ViewData["Title"] = "Edit Ghee Batch";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-primary mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Ghee Batch</h2>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="BatchNumber" class="form-label fw-semibold"></label>
                            <input asp-for="BatchNumber" class="form-control">
                        </div>
                        <div class="col-md-4">
                            <label asp-for="GheeType" class="form-label fw-semibold"></label>
                            <select asp-for="GheeType" asp-items="Html.GetEnumSelectList<DairyProductApp.Models.GheeType>()" class="form-select"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Quality" class="form-label fw-semibold"></label>
                            <select asp-for="Quality" asp-items="Html.GetEnumSelectList<DairyProductApp.Models.QualityGrade>()" class="form-select"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MilkUsedLiters" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="MilkUsedLiters" class="form-control" step="0.1">
                                <span class="input-group-text">L</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="GheeProducedKg" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="GheeProducedKg" class="form-control" step="0.01">
                                <span class="input-group-text">Kg</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PricePerKg" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">&#8377;</span>
                                <input asp-for="PricePerKg" class="form-control" step="0.01">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StockKg" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="StockKg" class="form-control" step="0.01">
                                <span class="input-group-text">Kg</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ProductionDate" class="form-label fw-semibold"></label>
                            <input asp-for="ProductionDate" class="form-control" type="date">
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ExpiryDate" class="form-label fw-semibold"></label>
                            <input asp-for="ExpiryDate" class="form-control" type="date">
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-semibold"></label>
                            <input asp-for="Description" class="form-control">
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-check-circle me-1"></i>Update</button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
