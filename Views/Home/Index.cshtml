@model DairyProductApp.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4 page-header">
    <div>
        <h3 class="fw-bold mb-1"><i class="bi bi-speedometer2 me-2 text-primary"></i>Dashboard</h3>
        <p class="text-muted mb-0 small">Welcome back, Admin! Raj Dairy ka complete overview</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="MilkCollection" asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i>New Collection
        </a>
    </div>
</div>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #3498db !important;">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small mb-1">Today's Milk</p>
                        <h4 class="fw-bold mb-0">@Model.TodayMilkCollection.ToString("F1") <small class="fs-6">L</small></h4>
                    </div>
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-cup-hot-fill"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #27ae60 !important;">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small mb-1">Total Farmers</p>
                        <h4 class="fw-bold mb-0">@Model.TotalFarmers</h4>
                    </div>
                    <div class="stat-icon bg-success bg-opacity-10 text-success">
                        <i class="bi bi-people-fill"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #e67e22 !important;">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small mb-1">Ghee Stock</p>
                        <h4 class="fw-bold mb-0">@Model.TotalGheeStock.ToString("F1") <small class="fs-6">Kg</small></h4>
                    </div>
                    <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                        <i class="bi bi-fire"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #8e44ad !important;">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small mb-1">Products</p>
                        <h4 class="fw-bold mb-0">@Model.TotalProducts</h4>
                    </div>
                    <div class="stat-icon" style="background:rgba(142,68,173,0.1);color:#8e44ad;">
                        <i class="bi bi-box-seam-fill"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #e74c3c !important;">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small mb-1">Avg Fat</p>
                        <h4 class="fw-bold mb-0">@Model.AvgFat.ToString("F1")%</h4>
                    </div>
                    <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                        <i class="bi bi-percent"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #1abc9c !important;">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small mb-1">Avg SNF</p>
                        <h4 class="fw-bold mb-0">@Model.AvgSNF.ToString("F1")%</h4>
                    </div>
                    <div class="stat-icon" style="background:rgba(26,188,156,0.1);color:#1abc9c;">
                        <i class="bi bi-graph-up"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <h6 class="fw-bold text-muted text-uppercase small"><i class="bi bi-lightning-fill text-warning me-1"></i>Quick Actions</h6>
    </div>
    <div class="col-md-3">
        <a asp-controller="MilkCollection" asp-action="Create" class="btn btn-primary w-100 py-3 shadow-sm">
            <i class="bi bi-plus-circle fs-4 d-block mb-1"></i>
            New Milk Collection
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="DairyProduct" asp-action="Create" class="btn btn-success w-100 py-3 shadow-sm">
            <i class="bi bi-box-seam fs-4 d-block mb-1"></i>
            Add Product
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="GheeProduct" asp-action="Create" class="btn btn-warning w-100 py-3 shadow-sm text-white">
            <i class="bi bi-fire fs-4 d-block mb-1"></i>
            New Ghee Batch
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="MilkRate" asp-action="Index" class="btn btn-info w-100 py-3 shadow-sm text-white">
            <i class="bi bi-currency-rupee fs-4 d-block mb-1"></i>
            Rate Chart
        </a>
    </div>
</div>

<!-- Recent Data Tables -->
<div class="row g-3">
    <div class="col-xl-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold"><i class="bi bi-clock-history text-primary me-2"></i>Recent Milk Collections</h6>
                <a asp-controller="MilkCollection" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Farmer</th>
                                <th>Type</th>
                                <th>Qty (L)</th>
                                <th>Fat%</th>
                                <th>SNF%</th>
                                <th>Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentCollections.Any())
                            {
                                @foreach (var item in Model.RecentCollections)
                                {
                                    <tr>
                                        <td class="fw-semibold">@item.FarmerName</td>
                                        <td><span class="badge bg-info">@item.MilkType</span></td>
                                        <td>@item.Quantity.ToString("F1")</td>
                                        <td>@item.FatPercentage.ToString("F1")%</td>
                                        <td>@item.SNFPercentage.ToString("F1")%</td>
                                        <td class="fw-bold text-success">&#8377;@item.TotalAmount.ToString("F0")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="6" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>Koi recent collection nahi hai</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold"><i class="bi bi-fire text-warning me-2"></i>Recent Ghee Production</h6>
                <a asp-controller="GheeProduct" asp-action="Index" class="btn btn-sm btn-outline-warning">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Batch</th>
                                <th>Type</th>
                                <th>Qty (Kg)</th>
                                <th>Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentGheeProduction.Any())
                            {
                                @foreach (var item in Model.RecentGheeProduction)
                                {
                                    <tr>
                                        <td class="fw-semibold">@item.BatchNumber</td>
                                        <td><span class="badge bg-warning text-dark">@item.GheeType</span></td>
                                        <td>@item.GheeProducedKg.ToString("F1")</td>
                                        <td class="fw-bold text-success">&#8377;@item.TotalValue.ToString("F0")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="4" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>Koi ghee production nahi hai</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
