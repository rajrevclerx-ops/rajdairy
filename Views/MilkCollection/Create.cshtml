@model DairyProductApp.Models.MilkCollection
@{
    ViewData["Title"] = "New Milk Collection";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-primary mb-0"><i class="bi bi-plus-circle me-2"></i>New Milk Collection</h2>
                <p class="text-muted mb-0">Naya milk collection entry karein</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FarmerName" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input asp-for="FarmerName" class="form-control" placeholder="Farmer ka naam">
                            </div>
                            <span asp-validation-for="FarmerName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MobileNumber" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-phone"></i></span>
                                <input asp-for="MobileNumber" class="form-control" placeholder="Mobile number">
                            </div>
                            <span asp-validation-for="MobileNumber" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MilkType" class="form-label fw-semibold"></label>
                            <select asp-for="MilkType" asp-items="Html.GetEnumSelectList<DairyProductApp.Models.MilkType>()" class="form-select" id="milkType">
                                <option value="">-- Select --</option>
                            </select>
                            <span asp-validation-for="MilkType" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Shift" class="form-label fw-semibold"></label>
                            <select asp-for="Shift" asp-items="Html.GetEnumSelectList<DairyProductApp.Models.Shift>()" class="form-select">
                            </select>
                            <span asp-validation-for="Shift" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CollectionDate" class="form-label fw-semibold"></label>
                            <input asp-for="CollectionDate" class="form-control" type="date">
                            <span asp-validation-for="CollectionDate" class="text-danger small"></span>
                        </div>

                        <div class="col-12"><hr class="my-1"></div>

                        <div class="col-md-4">
                            <label asp-for="Quantity" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="Quantity" class="form-control" placeholder="Liters" id="quantity" step="0.1">
                                <span class="input-group-text">L</span>
                            </div>
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FatPercentage" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="FatPercentage" class="form-control" placeholder="Fat %" id="fat" step="0.1">
                                <span class="input-group-text">%</span>
                            </div>
                            <span asp-validation-for="FatPercentage" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="SNFPercentage" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="SNFPercentage" class="form-control" placeholder="SNF %" id="snf" step="0.1">
                                <span class="input-group-text">%</span>
                            </div>
                            <span asp-validation-for="SNFPercentage" class="text-danger small"></span>
                        </div>

                        <!-- Auto Rate Display -->
                        <div class="col-md-4">
                            <label asp-for="RatePerLiter" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">&#8377;</span>
                                <input asp-for="RatePerLiter" class="form-control" id="rate" step="0.01">
                            </div>
                            <small class="text-info">Auto-calculated from rate chart</small>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Total Amount</label>
                            <div class="input-group">
                                <span class="input-group-text">&#8377;</span>
                                <input type="text" class="form-control fw-bold text-success" id="totalDisplay" readonly>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Remarks" class="form-label fw-semibold"></label>
                            <input asp-for="Remarks" class="form-control" placeholder="Optional remarks">
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-check-circle me-1"></i>Save Collection</button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function calculateRate() {
            var milkType = $('#milkType').val();
            var fat = parseFloat($('#fat').val()) || 0;
            var snf = parseFloat($('#snf').val()) || 0;
            var qty = parseFloat($('#quantity').val()) || 0;

            if (milkType && fat > 0 && snf > 0) {
                $.get('@Url.Action("GetRate", "MilkCollection")', { milkType: milkType, fat: fat, snf: snf }, function(data) {
                    if (data.ratePerLiter > 0) {
                        $('#rate').val(data.ratePerLiter.toFixed(2));
                    }
                    var rate = parseFloat($('#rate').val()) || 0;
                    var total = qty * rate;
                    $('#totalDisplay').val(total.toFixed(2));
                });
            } else {
                var rate = parseFloat($('#rate').val()) || 0;
                var total = qty * rate;
                $('#totalDisplay').val(total.toFixed(2));
            }
        }

        $('#milkType, #fat, #snf, #quantity, #rate').on('change keyup', calculateRate);
    </script>
}
