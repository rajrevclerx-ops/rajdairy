@model DairyProductApp.Models.MilkCollection
@{
    ViewData["Title"] = "Delete Milk Collection";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 text-center">
                <i class="bi bi-exclamation-triangle-fill text-danger fs-1 mb-3 d-block"></i>
                <h3 class="fw-bold">Kya aap sure hain?</h3>
                <p class="text-muted">Yeh milk collection record permanently delete ho jayega</p>
                <div class="card bg-light border-0 my-3">
                    <div class="card-body">
                        <p class="mb-1"><strong>Farmer:</strong> @Model.FarmerName</p>
                        <p class="mb-1"><strong>Date:</strong> @Model.CollectionDate.ToString("dd MMM yyyy") | <strong>Shift:</strong> @Model.Shift</p>
                        <p class="mb-1"><strong>Quantity:</strong> @Model.Quantity L | <strong>Fat:</strong> @Model.FatPercentage% | <strong>SNF:</strong> @Model.SNFPercentage%</p>
                        <p class="mb-0"><strong>Total Amount:</strong> <span class="text-success fw-bold">&#8377;@Model.TotalAmount.ToString("F2")</span></p>
                    </div>
                </div>
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="submit" class="btn btn-danger btn-lg"><i class="bi bi-trash me-1"></i>Ha, Delete Karein</button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
