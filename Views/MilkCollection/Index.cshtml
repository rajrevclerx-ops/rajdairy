@model IEnumerable<DairyProductApp.Models.MilkCollection>
@{
    ViewData["Title"] = "Milk Collections";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-primary mb-0"><i class="bi bi-cup-hot-fill me-2"></i>Milk Collections</h2>
        <p class="text-muted mb-0">Sabhi milk collections ka record</p>
    </div>
    <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="bi bi-plus-circle me-1"></i>New Collection</a>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Farmer Name</label>
                <input type="text" name="searchFarmer" class="form-control" value="@ViewBag.SearchFarmer" placeholder="Search farmer...">
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Milk Type</label>
                <select name="milkType" class="form-select">
                    <option value="">All</option>
                    <option value="Cow" selected="@(ViewBag.MilkType?.ToString() == "Cow")">Cow</option>
                    <option value="Buffalo" selected="@(ViewBag.MilkType?.ToString() == "Buffalo")">Buffalo</option>
                    <option value="Mixed" selected="@(ViewBag.MilkType?.ToString() == "Mixed")">Mixed</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">From Date</label>
                <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate">
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">To Date</label>
                <input type="date" name="toDate" class="form-control" value="@ViewBag.ToDate">
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-search me-1"></i>Search</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-circle me-1"></i>Clear</a>
            </div>
        </form>
    </div>
</div>

<!-- Summary -->
@if (Model.Any())
{
    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <div class="card border-0 bg-primary bg-opacity-10">
                <div class="card-body py-2 text-center">
                    <small class="text-muted">Total Quantity</small>
                    <h5 class="fw-bold text-primary mb-0">@Model.Sum(m => m.Quantity).ToString("F1") L</h5>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-success bg-opacity-10">
                <div class="card-body py-2 text-center">
                    <small class="text-muted">Total Amount</small>
                    <h5 class="fw-bold text-success mb-0">&#8377;@Model.Sum(m => m.TotalAmount).ToString("F0")</h5>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-warning bg-opacity-10">
                <div class="card-body py-2 text-center">
                    <small class="text-muted">Avg Fat</small>
                    <h5 class="fw-bold text-warning mb-0">@Model.Average(m => m.FatPercentage).ToString("F2")%</h5>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-info bg-opacity-10">
                <div class="card-body py-2 text-center">
                    <small class="text-muted">Avg SNF</small>
                    <h5 class="fw-bold text-info mb-0">@Model.Average(m => m.SNFPercentage).ToString("F2")%</h5>
                </div>
            </div>
        </div>
    </div>
}

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Date</th>
                        <th>Shift</th>
                        <th>Farmer</th>
                        <th>Type</th>
                        <th>Qty (L)</th>
                        <th>Fat%</th>
                        <th>SNF%</th>
                        <th>Rate/L</th>
                        <th>Total</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        int sn = 1;
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@(sn++)</td>
                                <td>@item.CollectionDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.Shift == DairyProductApp.Models.Shift.Morning)
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-sunrise me-1"></i>Morning</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-dark"><i class="bi bi-sunset me-1"></i>Evening</span>
                                    }
                                </td>
                                <td class="fw-semibold">@item.FarmerName</td>
                                <td>
                                    @if (item.MilkType == DairyProductApp.Models.MilkType.Cow)
                                    {
                                        <span class="badge bg-info">Cow</span>
                                    }
                                    else if (item.MilkType == DairyProductApp.Models.MilkType.Buffalo)
                                    {
                                        <span class="badge bg-primary">Buffalo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Mixed</span>
                                    }
                                </td>
                                <td>@item.Quantity.ToString("F1")</td>
                                <td><span class="badge bg-danger bg-opacity-75">@item.FatPercentage.ToString("F1")%</span></td>
                                <td><span class="badge bg-success bg-opacity-75">@item.SNFPercentage.ToString("F1")%</span></td>
                                <td>&#8377;@item.RatePerLiter.ToString("F2")</td>
                                <td class="fw-bold text-success">&#8377;@item.TotalAmount.ToString("F0")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="Details"><i class="bi bi-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Edit"><i class="bi bi-pencil"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="11" class="text-center text-muted py-5"><i class="bi bi-inbox fs-1 d-block mb-2"></i>Koi milk collection nahi mili. Naya add karein!</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
