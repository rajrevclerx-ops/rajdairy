@{
    ViewData["Title"] = "Quick Milk Entry";
    var partners = ViewBag.Partners as List<DairyProductApp.Models.Partner> ?? new();
    var currentShift = ViewBag.CurrentShift as string ?? "Morning";
    var whatsAppUrl = TempData["WhatsAppUrl"] as string;
    var receiptJson = TempData["ReceiptData"] as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-lightning-charge-fill me-2 text-warning"></i>Quick Milk Entry</h3>
        <p class="text-muted mb-0 small">Farmer select karo, sirf Qty/Fat/SNF dalo - done!</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-list-ul me-1"></i>All Records</a>
</div>

<!-- Receipt Modal (shows after save) -->
@if (receiptJson != null)
{
    <div class="modal fade show d-block" id="receiptModal" style="background:rgba(0,0,0,0.6);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:20px;border:none;">
                <div class="modal-body p-0">
                    <!-- Receipt -->
                    <div id="receiptPrint" style="background:white;border-radius:20px;">
                        <div class="text-center p-4" style="background:linear-gradient(135deg,#0f172a,#1e293b);border-radius:20px 20px 0 0;color:white;">
                            <i class="bi bi-droplet-fill fs-3 d-block mb-1"></i>
                            <h5 class="fw-bold mb-0">Raj Dairy</h5>
                            <small style="opacity:0.6;">Milk Collection Receipt</small>
                        </div>
                        <div class="p-4" id="receiptContent"></div>
                    </div>
                    <!-- Actions -->
                    <div class="p-3 d-flex gap-2">
                        <a href="@whatsAppUrl" target="_blank" class="btn btn-success flex-fill" style="border-radius:12px;">
                            <i class="bi bi-whatsapp me-1"></i>WhatsApp
                        </a>
                        <button onclick="window.print()" class="btn btn-primary flex-fill" style="border-radius:12px;">
                            <i class="bi bi-printer me-1"></i>Print
                        </button>
                        <button onclick="document.getElementById('receiptModal').remove()" class="btn btn-outline-secondary" style="border-radius:12px;">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="row g-3">
    <!-- Left: Quick Entry Form -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm" style="border-radius:16px;">
            <div class="card-body p-4">
                <form asp-action="QuickEntry" method="post" id="quickForm">
                    @Html.AntiForgeryToken()

                    <!-- Step 1: Farmer Select -->
                    <div class="mb-3">
                        <label class="form-label fw-bold"><i class="bi bi-person-fill text-primary me-1"></i>Farmer / Partner Select Karo</label>
                        <select id="farmerSelect" class="form-select form-select-lg" style="border-radius:12px;border:2px solid #e2e8f0;padding:12px 16px;" onchange="loadFarmer()">
                            <option value="">-- Farmer Chunein --</option>
                            @foreach (var p in partners)
                            {
                                <option value="@p.Id" data-name="@p.Name" data-mobile="@p.Mobile">@p.Name (@p.Mobile)</option>
                            }
                        </select>
                        <input type="hidden" name="FarmerName" id="farmerName" />
                        <input type="hidden" name="MobileNumber" id="farmerMobile" />
                    </div>

                    <!-- Farmer Info Card (auto-filled) -->
                    <div id="farmerCard" class="card border-0 mb-3 d-none" style="background:linear-gradient(135deg,#eff6ff,#dbeafe);border-radius:14px;">
                        <div class="card-body py-3 d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="fw-bold mb-0" id="displayName">-</h6>
                                <small class="text-muted" id="displayMobile">-</small>
                            </div>
                            <div class="text-end">
                                <small class="text-muted">Last entry:</small>
                                <div class="fw-bold text-primary" id="lastEntryInfo">-</div>
                            </div>
                        </div>
                    </div>

                    <!-- Step 2: Shift & Date -->
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold small">Shift</label>
                            <div class="d-flex gap-2">
                                <input type="radio" name="Shift" value="Morning" id="shiftMorning" class="btn-check" checked="@(currentShift == "Morning")">
                                <label for="shiftMorning" class="btn btn-outline-warning flex-fill" style="border-radius:10px;">
                                    <i class="bi bi-sunrise me-1"></i>Morning
                                </label>
                                <input type="radio" name="Shift" value="Evening" id="shiftEvening" class="btn-check" checked="@(currentShift == "Evening")">
                                <label for="shiftEvening" class="btn btn-outline-dark flex-fill" style="border-radius:10px;">
                                    <i class="bi bi-sunset me-1"></i>Evening
                                </label>
                            </div>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold small">Date</label>
                            <input type="date" name="CollectionDate" class="form-control" value="@ViewBag.Today" style="border-radius:10px;">
                        </div>
                    </div>

                    <!-- Step 3: Milk Type -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Milk Type</label>
                        <div class="d-flex gap-2">
                            <input type="radio" name="MilkType" value="Cow" id="typeCow" class="btn-check" checked>
                            <label for="typeCow" class="btn btn-outline-info flex-fill" style="border-radius:10px;">Cow</label>
                            <input type="radio" name="MilkType" value="Buffalo" id="typeBuffalo" class="btn-check">
                            <label for="typeBuffalo" class="btn btn-outline-primary flex-fill" style="border-radius:10px;">Buffalo</label>
                            <input type="radio" name="MilkType" value="Mixed" id="typeMixed" class="btn-check">
                            <label for="typeMixed" class="btn btn-outline-secondary flex-fill" style="border-radius:10px;">Mixed</label>
                        </div>
                    </div>

                    <!-- Step 4: Qty, Fat, SNF - THE MAIN INPUT -->
                    <div class="card border-0 p-3 mb-3" style="background:#f8fafc;border-radius:14px;">
                        <div class="row g-2">
                            <div class="col-4">
                                <label class="form-label fw-bold small text-center d-block">Quantity (L)</label>
                                <input name="Quantity" type="number" step="0.1" class="form-control form-control-lg text-center fw-bold" id="qty"
                                       style="border-radius:12px;border:2px solid #3b82f6;font-size:1.3rem;" placeholder="0.0" autofocus>
                            </div>
                            <div class="col-4">
                                <label class="form-label fw-bold small text-center d-block">Fat %</label>
                                <input name="FatPercentage" type="number" step="0.1" class="form-control form-control-lg text-center fw-bold" id="fat"
                                       style="border-radius:12px;border:2px solid #ef4444;font-size:1.3rem;" placeholder="0.0">
                            </div>
                            <div class="col-4">
                                <label class="form-label fw-bold small text-center d-block">SNF %</label>
                                <input name="SNFPercentage" type="number" step="0.1" class="form-control form-control-lg text-center fw-bold" id="snf"
                                       style="border-radius:12px;border:2px solid #22c55e;font-size:1.3rem;" placeholder="0.0">
                            </div>
                        </div>
                    </div>

                    <!-- Rate (optional manual) -->
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold small">Rate/Liter (Auto)</label>
                            <div class="input-group">
                                <span class="input-group-text" style="border-radius:10px 0 0 10px;">&#8377;</span>
                                <input name="RatePerLiter" type="number" step="0.01" class="form-control" id="rate" style="border-radius:0 10px 10px 0;">
                            </div>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold small">Remarks</label>
                            <input name="Remarks" class="form-control" placeholder="Optional" style="border-radius:10px;">
                        </div>
                    </div>

                    <!-- Total Display -->
                    <div class="card border-0 p-3 mb-3 text-center" style="background:linear-gradient(135deg,#0f172a,#1e293b);border-radius:14px;color:white;">
                        <small style="opacity:0.6;">Total Amount</small>
                        <h2 class="fw-bold mb-0" id="totalDisplay">&#8377;0.00</h2>
                    </div>

                    <!-- Submit -->
                    <button type="submit" class="btn btn-primary btn-lg w-100" style="border-radius:14px;padding:14px;" id="submitBtn" disabled>
                        <i class="bi bi-check-circle-fill me-2"></i>Save & Send Receipt
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Right: Today's Summary -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm mb-3" style="border-radius:16px;">
            <div class="card-header bg-white border-0" style="border-radius:16px 16px 0 0;">
                <h6 class="fw-bold mb-0"><i class="bi bi-clock-history text-primary me-2"></i>Today's Collection</h6>
            </div>
            <div class="card-body p-0" id="todayList">
                <div class="text-center text-muted py-4">
                    <i class="bi bi-cup-hot fs-3 d-block mb-1" style="opacity:0.3;"></i>
                    <small>Loading...</small>
                </div>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="card border-0 shadow-sm" style="border-radius:16px;">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="bi bi-bar-chart text-success me-2"></i>Quick Stats</h6>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Today's Total Milk</span>
                    <span class="fw-bold" id="statTotalMilk">-</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Today's Revenue</span>
                    <span class="fw-bold text-success" id="statRevenue">-</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Farmers Today</span>
                    <span class="fw-bold" id="statFarmers">-</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted small">Avg Fat / SNF</span>
                    <span class="fw-bold" id="statAvg">-</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Print Styles -->
<style>
    @@media print {
        body * { visibility: hidden; }
        #receiptPrint, #receiptPrint * { visibility: visible; }
        #receiptPrint { position: absolute; left: 50%; top: 0; transform: translateX(-50%); width: 300px; }
        .modal { background: white !important; }
    }
</style>

@section Scripts {
<script>
    // Load farmer details when selected
    function loadFarmer() {
        var sel = $('#farmerSelect');
        var opt = sel.find(':selected');
        if (!opt.val()) {
            $('#farmerCard').addClass('d-none');
            $('#submitBtn').prop('disabled', true);
            return;
        }

        var name = opt.data('name');
        var mobile = opt.data('mobile');
        $('#farmerName').val(name);
        $('#farmerMobile').val(mobile);
        $('#displayName').text(name);
        $('#displayMobile').text(mobile);
        $('#farmerCard').removeClass('d-none');
        $('#submitBtn').prop('disabled', false);

        // Get last entry data
        $.get('@Url.Action("GetPartnerDetails")', { partnerId: opt.val() }, function(data) {
            if (data.found) {
                if (data.lastQty > 0) {
                    $('#lastEntryInfo').text(data.lastQty + 'L | Fat:' + data.lastFat + '% | SNF:' + data.lastSnf + '%');
                    // Pre-select milk type
                    $('input[name="MilkType"][value="' + data.milkType + '"]').prop('checked', true);
                } else {
                    $('#lastEntryInfo').text('New farmer');
                }
            }
        });
    }

    // Auto-calculate rate and total
    function calculate() {
        var milkType = $('input[name="MilkType"]:checked').val();
        var qty = parseFloat($('#qty').val()) || 0;
        var fat = parseFloat($('#fat').val()) || 0;
        var snf = parseFloat($('#snf').val()) || 0;

        if (milkType && fat > 0 && snf > 0) {
            $.get('@Url.Action("GetRate")', { milkType: milkType, fat: fat, snf: snf }, function(data) {
                if (data.ratePerLiter > 0) {
                    $('#rate').val(data.ratePerLiter.toFixed(2));
                }
                updateTotal();
            });
        } else {
            updateTotal();
        }
    }

    function updateTotal() {
        var qty = parseFloat($('#qty').val()) || 0;
        var rate = parseFloat($('#rate').val()) || 0;
        var total = qty * rate;
        $('#totalDisplay').html('&#8377;' + total.toFixed(2));
    }

    $('#qty, #fat, #snf, #rate').on('change keyup', calculate);
    $('input[name="MilkType"]').on('change', calculate);

    // Load today's collections
    $(function () {
        $.get('@Url.Action("Index")', { fromDate: '@ViewBag.Today', toDate: '@ViewBag.Today' }, function(html) {
            // We'll load via API instead
        });

        // Quick stats - load from existing data
        loadTodayStats();
    });

    function loadTodayStats() {
        // This will be populated from the page data
        var today = '@ViewBag.Today';
        $.get('@Url.Action("GetTodayStats")', function(data) {
            $('#statTotalMilk').text(data.totalMilk + ' L');
            $('#statRevenue').text('₹' + data.totalRevenue);
            $('#statFarmers').text(data.totalFarmers);
            $('#statAvg').text('F:' + data.avgFat + '% / S:' + data.avgSnf + '%');

            // Build today's list
            var html = '';
            if (data.entries && data.entries.length > 0) {
                data.entries.forEach(function(e) {
                    html += '<div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">';
                    html += '<div><span class="fw-semibold" style="font-size:0.85rem;">' + e.name + '</span>';
                    html += '<small class="text-muted d-block">' + e.shift + ' | ' + e.milkType + ' | Fat:' + e.fat + '% SNF:' + e.snf + '%</small></div>';
                    html += '<div class="text-end"><span class="fw-bold" style="font-size:0.85rem;">' + e.qty + ' L</span>';
                    html += '<small class="text-success d-block fw-bold">₹' + e.amount + '</small></div></div>';
                });
            } else {
                html = '<div class="text-center text-muted py-4"><i class="bi bi-cup-hot fs-3 d-block mb-1" style="opacity:0.3;"></i><small>Aaj koi collection nahi</small></div>';
            }
            $('#todayList').html(html);
        }).fail(function() {
            $('#todayList').html('<div class="text-center text-muted py-3"><small>Data load nahi hua</small></div>');
        });
    }

    // Receipt content
    @if (receiptJson != null)
    {
        <text>
        var receipt = @Html.Raw(receiptJson);
        var rHtml = '<table style="width:100%;font-size:0.9rem;">';
        rHtml += '<tr><td class="text-muted py-1">Farmer</td><td class="fw-bold text-end">' + receipt.FarmerName + '</td></tr>';
        rHtml += '<tr><td class="text-muted py-1">Date</td><td class="fw-bold text-end">' + receipt.Date + '</td></tr>';
        rHtml += '<tr><td class="text-muted py-1">Shift</td><td class="fw-bold text-end">' + receipt.Shift + '</td></tr>';
        rHtml += '<tr><td class="text-muted py-1">Milk Type</td><td class="fw-bold text-end">' + receipt.MilkType + '</td></tr>';
        rHtml += '<tr><td colspan="2"><hr class="my-1"></td></tr>';
        rHtml += '<tr><td class="text-muted py-1">Quantity</td><td class="fw-bold text-end">' + receipt.Qty + ' L</td></tr>';
        rHtml += '<tr><td class="text-muted py-1">Fat</td><td class="fw-bold text-end">' + receipt.Fat + '%</td></tr>';
        rHtml += '<tr><td class="text-muted py-1">SNF</td><td class="fw-bold text-end">' + receipt.SNF + '%</td></tr>';
        rHtml += '<tr><td class="text-muted py-1">Rate/L</td><td class="fw-bold text-end">₹' + receipt.Rate + '</td></tr>';
        rHtml += '<tr><td colspan="2"><hr class="my-1"></td></tr>';
        rHtml += '<tr><td class="py-2 fs-5 fw-bold">Total</td><td class="text-end py-2 fs-4 fw-bold text-success">₹' + receipt.Total + '</td></tr>';
        rHtml += '</table>';
        rHtml += '<div class="text-center mt-2"><small class="text-muted">Thank you! - Raj Dairy</small></div>';
        $('#receiptContent').html(rHtml);
        </text>
    }
</script>
}
