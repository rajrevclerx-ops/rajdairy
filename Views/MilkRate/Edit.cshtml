@model DairyProductApp.Models.MilkRate
@{
    ViewData["Title"] = "Edit Milk Rate";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-primary mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Milk Rate</h2>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <input type="hidden" asp-for="Id" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="MilkType" class="form-label fw-semibold"></label>
                            <select asp-for="MilkType" asp-items="Html.GetEnumSelectList<DairyProductApp.Models.MilkType>()" class="form-select"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RatePerLiter" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">&#8377;</span>
                                <input asp-for="RatePerLiter" class="form-control" step="0.01">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MinFat" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="MinFat" class="form-control" step="0.1">
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MaxFat" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="MaxFat" class="form-control" step="0.1">
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MinSNF" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="MinSNF" class="form-control" step="0.1">
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MaxSNF" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="MaxSNF" class="form-control" step="0.1">
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EffectiveFrom" class="form-label fw-semibold"></label>
                            <input asp-for="EffectiveFrom" class="form-control" type="date">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IsActive" class="form-label fw-semibold d-block"></label>
                            <div class="form-check form-switch mt-2">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch">
                                <label class="form-check-label">Active</label>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-check-circle me-1"></i>Update</button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
