@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-inbox fs-1 text-muted d-block mb-2"></i>
        <p class="text-muted">Koi rate set nahi hai. Naya rate add karein!</p>
    </div>
}
