@model List<DairyProductApp.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
}

<div class="d-flex justify-content-between align-items-center mb-4 page-header">
    <div>
        <h3 class="fw-bold mb-1"><i class="bi bi-bell me-2 text-primary"></i>Notifications</h3>
        <p class="text-muted mb-0 small">Saari notifications yahan dekhein - @Model.Count(n => !n.IsRead) unread</p>
    </div>
    @if (Model.Any(n => !n.IsRead))
    {
        <form asp-action="MarkAllRead" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-primary">
                <i class="bi bi-check-all me-1"></i>Mark All Read
            </button>
        </form>
    }
</div>

@if (Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            @foreach (var notif in Model)
            {
                var bgClass = notif.IsRead ? "" : "bg-primary bg-opacity-10";
                var typeColor = notif.Type switch {
                    DairyProductApp.Models.NotificationType.Success => "text-success",
                    DairyProductApp.Models.NotificationType.Warning => "text-warning",
                    DairyProductApp.Models.NotificationType.Danger => "text-danger",
                    DairyProductApp.Models.NotificationType.Order => "text-primary",
                    DairyProductApp.Models.NotificationType.Payment => "text-success",
                    DairyProductApp.Models.NotificationType.Subscription => "text-info",
                    DairyProductApp.Models.NotificationType.Stock => "text-warning",
                    _ => "text-primary"
                };
                <div class="notification-item @bgClass" style="padding:1rem 1.5rem;">
                    <div class="notification-icon bg-light @typeColor">
                        <i class="bi @(notif.Icon ?? "bi-info-circle")"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="fw-bold mb-1 small">@notif.Title</h6>
                                <p class="text-muted mb-0 small">@notif.Message</p>
                            </div>
                            <div class="text-end">
                                <small class="text-muted d-block">@notif.CreatedAt.ToString("dd MMM HH:mm")</small>
                                @if (!notif.IsRead)
                                {
                                    <span class="pulse-indicator green mt-1"></span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body empty-state">
            <i class="bi bi-bell-slash"></i>
            <h6>Koi notification nahi hai</h6>
            <p class="text-muted">Jab koi naya event hoga tab notification aayegi</p>
        </div>
    </div>
}
