@model DairyProductApp.Models.Order
@{
    ViewData["Title"] = "Delete Order";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 text-center">
                <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:3rem;"></i>
                <h4 class="fw-bold mt-3">Order Delete Karein?</h4>
                <p class="text-muted">Order <strong>#@Model.OrderNumber</strong> permanently delete ho jayega.</p>

                <div class="card bg-light border-0 mb-4">
                    <div class="card-body">
                        <p class="mb-1"><strong>Partner:</strong> @Model.PartnerName</p>
                        <p class="mb-1"><strong>Product:</strong> @Model.ProductName - @Model.Quantity @Model.Unit</p>
                        <p class="mb-0"><strong>Amount:</strong> &#8377;@Model.TotalAmount.ToString("N0")</p>
                    </div>
                </div>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="submit" class="btn btn-danger btn-lg"><i class="bi bi-trash me-1"></i>Haan, Delete Karo</button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
