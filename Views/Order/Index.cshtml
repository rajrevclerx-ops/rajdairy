@model List<DairyProductApp.Models.Order>
@{
    ViewData["Title"] = "Orders";
}

<div class="d-flex justify-content-between align-items-center mb-4 page-header">
    <div>
        <h3 class="fw-bold mb-1"><i class="bi bi-bag-check me-2" style="color:#7c3aed;"></i>Order Management</h3>
        <p class="text-muted mb-0 small">Saare orders track aur manage karein</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>New Order
    </a>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    @{
        var pending = Model.Count(o => o.Status == DairyProductApp.Models.OrderStatus.Pending);
        var confirmed = Model.Count(o => o.Status == DairyProductApp.Models.OrderStatus.Confirmed);
        var delivered = Model.Count(o => o.Status == DairyProductApp.Models.OrderStatus.Delivered);
        var totalValue = Model.Sum(o => o.TotalAmount);
    }
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-3 d-flex align-items-center gap-3">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning"><i class="bi bi-clock-fill"></i></div>
                <div><p class="text-muted small mb-0">Pending</p><h4 class="fw-bold mb-0">@pending</h4></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-3 d-flex align-items-center gap-3">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-check2-circle"></i></div>
                <div><p class="text-muted small mb-0">Confirmed</p><h4 class="fw-bold mb-0">@confirmed</h4></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-3 d-flex align-items-center gap-3">
                <div class="stat-icon bg-success bg-opacity-10 text-success"><i class="bi bi-check-circle-fill"></i></div>
                <div><p class="text-muted small mb-0">Delivered</p><h4 class="fw-bold mb-0">@delivered</h4></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-3 d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:rgba(124,58,237,0.1);color:#7c3aed;"><i class="bi bi-currency-rupee"></i></div>
                <div><p class="text-muted small mb-0">Total Value</p><h4 class="fw-bold mb-0">@totalValue.ToString("N0")</h4></div>
            </div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <div class="search-bar">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" name="search" class="form-control" placeholder="Order #, Partner, Product..." value="@ViewBag.Search" />
                </div>
            </div>
            <div class="col-md-3">
                <select name="status" class="form-select">
                    <option value="">All Status</option>
                    <option value="Pending">Pending</option>
                    <option value="Confirmed">Confirmed</option>
                    <option value="OutForDelivery">Out for Delivery</option>
                    <option value="Delivered">Delivered</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-funnel me-1"></i>Filter</button>
            </div>
            <div class="col-md-2">
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
            </div>
        </form>
    </div>
</div>

<!-- Orders Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Order #</th>
                        <th>Partner</th>
                        <th>Product</th>
                        <th>Qty</th>
                        <th>Amount</th>
                        <th>Delivery</th>
                        <th>Status</th>
                        <th>Payment</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var order in Model)
                        {
                            var statusClass = order.Status switch {
                                DairyProductApp.Models.OrderStatus.Pending => "badge-soft-warning",
                                DairyProductApp.Models.OrderStatus.Confirmed => "badge-soft-primary",
                                DairyProductApp.Models.OrderStatus.OutForDelivery => "badge-soft-info",
                                DairyProductApp.Models.OrderStatus.Delivered => "badge-soft-success",
                                DairyProductApp.Models.OrderStatus.Cancelled => "badge-soft-danger",
                                _ => "badge-soft-secondary"
                            };
                            var payClass = order.PaymentStatus switch {
                                DairyProductApp.Models.PaymentStatus.Paid => "badge-soft-success",
                                DairyProductApp.Models.PaymentStatus.Pending => "badge-soft-warning",
                                DairyProductApp.Models.PaymentStatus.Partial => "badge-soft-info",
                                _ => "badge-soft-secondary"
                            };
                            <tr>
                                <td class="fw-semibold small">@order.OrderNumber</td>
                                <td>@order.PartnerName</td>
                                <td>@order.ProductName</td>
                                <td>@order.Quantity @order.Unit</td>
                                <td class="fw-bold text-success">&#8377;@order.TotalAmount.ToString("N0")</td>
                                <td class="small">@order.DeliveryDate.ToString("dd MMM")<br/><span class="text-muted">@order.DeliverySlot</span></td>
                                <td><span class="badge @statusClass">@order.Status</span></td>
                                <td><span class="badge @payClass">@order.PaymentStatus</span></td>
                                <td>
                                    <div class="d-flex gap-1 justify-content-end">
                                        @if (order.Status == DairyProductApp.Models.OrderStatus.Pending)
                                        {
                                            <form asp-action="UpdateStatus" method="post">
                                                <input type="hidden" name="id" value="@order.Id" />
                                                <input type="hidden" name="newStatus" value="Confirmed" />
                                                <button class="btn btn-sm btn-outline-primary" title="Confirm"><i class="bi bi-check2"></i></button>
                                            </form>
                                        }
                                        @if (order.Status == DairyProductApp.Models.OrderStatus.Confirmed)
                                        {
                                            <form asp-action="UpdateStatus" method="post">
                                                <input type="hidden" name="id" value="@order.Id" />
                                                <input type="hidden" name="newStatus" value="OutForDelivery" />
                                                <button class="btn btn-sm btn-outline-info" title="Dispatch"><i class="bi bi-truck"></i></button>
                                            </form>
                                        }
                                        @if (order.Status == DairyProductApp.Models.OrderStatus.OutForDelivery)
                                        {
                                            <form asp-action="UpdateStatus" method="post">
                                                <input type="hidden" name="id" value="@order.Id" />
                                                <input type="hidden" name="newStatus" value="Delivered" />
                                                <button class="btn btn-sm btn-outline-success" title="Mark Delivered"><i class="bi bi-check-circle"></i></button>
                                            </form>
                                        }
                                        <a asp-action="Invoice" asp-route-id="@order.Id" class="btn btn-sm btn-outline-secondary" title="Invoice"><i class="bi bi-receipt"></i></a>
                                        <a asp-action="Edit" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary" title="Edit"><i class="bi bi-pencil"></i></a>
                                        <a asp-action="Delete" asp-route-id="@order.Id" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="9" class="empty-state"><i class="bi bi-inbox fs-3 d-block mb-2"></i>Koi order nahi mila</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
