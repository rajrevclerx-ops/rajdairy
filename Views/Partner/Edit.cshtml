@model DairyProductApp.Models.Partner
@{ ViewData["Title"] = "Edit Partner"; }

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold text-primary mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Partner</h3>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
        </div>
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="AccessCode" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Mobile" class="form-label fw-semibold"></label>
                            <input asp-for="Mobile" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Type" class="form-label fw-semibold"></label>
                            <select asp-for="Type" asp-items="Html.GetEnumSelectList<DairyProductApp.Models.PartnerType>()" class="form-select"></select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Access Code</label>
                            <input type="text" class="form-control fw-bold" value="@Model.AccessCode" readonly>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IsActive" class="form-label fw-semibold d-block"></label>
                            <div class="form-check form-switch mt-2">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch">
                                <label class="form-check-label">Active</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="Address" class="form-label fw-semibold"></label>
                            <input asp-for="Address" class="form-control">
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-check-circle me-1"></i>Update</button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
