@{
    ViewData["Title"] = "Partner Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Raj Dairy - Partner Login</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        body { background: linear-gradient(135deg, #1a3a5c 0%, #2e86c1 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; font-family: 'Segoe UI', sans-serif; }
        .login-card { max-width: 420px; width: 100%; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="card border-0 shadow-lg" style="border-radius:16px;">
            <div class="card-body p-5 text-center">
                <div class="mb-4">
                    <div class="mx-auto" style="width:70px;height:70px;border-radius:50%;background:linear-gradient(135deg,#1a5276,#2e86c1);display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-droplet-fill text-white fs-2"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-1">Raj Dairy</h3>
                <p class="text-muted mb-4">Apna Access Code dalein aur apna hisab dekhein</p>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger small"><i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.Error</div>
                }

                <form asp-action="Login" method="post">
                    <div class="mb-3">
                        <div class="input-group input-group-lg">
                            <span class="input-group-text" style="border-radius:12px 0 0 12px;"><i class="bi bi-key-fill"></i></span>
                            <input type="text" name="accessCode" class="form-control text-center fw-bold"
                                   placeholder="Access Code (e.g. RD0001)" maxlength="10"
                                   style="border-radius:0 12px 12px 0;letter-spacing:3px;font-size:1.3rem;"
                                   autofocus required>
                        </div>
                        <small class="text-muted d-block mt-2">Admin se apna Access Code le</small>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100" style="border-radius:12px;">
                        <i class="bi bi-box-arrow-in-right me-2"></i>View My Account
                    </button>
                </form>

                <hr class="my-4">
                <p class="small text-muted mb-0">
                    <i class="bi bi-shield-lock me-1"></i>Sirf dekhne ka access hai, koi changes nahi ho sakte
                </p>
            </div>
        </div>
        <div class="text-center mt-3">
            <a href="/" class="text-white-50 small text-decoration-none"><i class="bi bi-arrow-left me-1"></i>Admin Login</a>
        </div>
    </div>
</body>
</html>
