@{
    ViewData["Title"] = "Partner Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Raj Dairy - Partner Portal</title>
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0f172a" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { font-family: 'Inter', sans-serif; }
        body { background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 1rem; }
        .login-card { max-width: 420px; width: 100%; animation: slideUp 0.5s ease; }
        .glass-card { background: rgba(255,255,255,0.95); backdrop-filter: blur(20px); border-radius: 24px; border: 1px solid rgba(255,255,255,0.2); }
        .brand-icon { width: 80px; height: 80px; border-radius: 20px; background: linear-gradient(135deg, #2563eb, #7c3aed); display: flex; align-items: center; justify-content: center; margin: 0 auto; box-shadow: 0 8px 32px rgba(37,99,235,0.3); }
        .input-modern { border-radius: 14px !important; border: 2px solid #e2e8f0; padding: 14px 18px; font-size: 1.2rem; letter-spacing: 3px; text-align: center; font-weight: 700; transition: all 0.3s; }
        .input-modern:focus { border-color: #2563eb; box-shadow: 0 0 0 4px rgba(37,99,235,0.1); }
        .btn-modern { border-radius: 14px; padding: 14px; font-weight: 600; font-size: 1.05rem; transition: all 0.3s; }
        .btn-modern:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(37,99,235,0.3); }
        .feature-item { display: flex; align-items: center; gap: 10px; padding: 8px 0; }
        .feature-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; }
        .divider { display: flex; align-items: center; gap: 12px; color: #94a3b8; font-size: 0.8rem; }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: #e2e8f0; }
        @@keyframes slideUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="glass-card shadow-lg">
            <div class="p-4 p-md-5">
                <!-- Brand -->
                <div class="text-center mb-4">
                    <div class="brand-icon mb-3">
                        <i class="bi bi-droplet-fill text-white" style="font-size: 2.2rem;"></i>
                    </div>
                    <h3 class="fw-800 mb-1" style="color:#0f172a;">Raj Dairy</h3>
                    <p class="text-muted mb-0" style="font-size:0.9rem;">Partner Portal - Apna Hisab Dekhein</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger small py-2 text-center" style="border-radius:12px;border:none;background:rgba(239,68,68,0.1);color:#dc2626;">
                        <i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.Error
                    </div>
                }

                <!-- Login Form -->
                <form asp-action="Login" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-600 small text-muted">ACCESS CODE</label>
                        <input type="text" name="accessCode" class="form-control input-modern"
                               placeholder="RD0001" maxlength="10" autofocus required
                               oninput="this.value=this.value.toUpperCase()">
                        <small class="text-muted mt-1 d-block text-center">Admin se apna code lein</small>
                    </div>
                    <button type="submit" class="btn btn-primary btn-modern w-100 mb-3">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Mera Account Dekhein
                    </button>
                </form>

                <!-- Features -->
                <div class="divider my-3">Aapko milega</div>
                <div class="mb-3">
                    <div class="feature-item">
                        <div class="feature-icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-journal-text"></i></div>
                        <small class="text-muted">Complete hisab-kitab dekhein</small>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon bg-success bg-opacity-10 text-success"><i class="bi bi-bag-check"></i></div>
                        <small class="text-muted">Order status track karein</small>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon bg-info bg-opacity-10 text-info"><i class="bi bi-calendar-check"></i></div>
                        <small class="text-muted">Subscription details dekhein</small>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon bg-warning bg-opacity-10 text-warning"><i class="bi bi-credit-card"></i></div>
                        <small class="text-muted">QR / UPI se payment karein</small>
                    </div>
                </div>

                <div class="divider my-3">ya</div>

                <!-- Track Order -->
                <a href="/Public/TrackOrder" class="btn btn-outline-secondary btn-modern w-100 mb-2">
                    <i class="bi bi-truck me-2"></i>Order Track Karein
                </a>
            </div>
        </div>
        <div class="text-center mt-3">
            <small class="text-white" style="opacity:0.3;">Powered by Raj Dairy Pro v2.1</small>
        </div>
    </div>

    <script>if ('serviceWorker' in navigator) { navigator.serviceWorker.register('/sw.js'); }</script>
</body>
</html>
