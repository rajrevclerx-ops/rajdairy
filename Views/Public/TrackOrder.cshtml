@model DairyProductApp.Models.Order?
@{
    ViewData["Title"] = "Track Order";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Raj Dairy - Track Order</title>
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0f172a" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        body { background: #f0f2f5; font-family: 'Segoe UI', sans-serif; }
        .top-bar { background: linear-gradient(135deg, #1a3a5c 0%, #2e86c1 100%); }
        .track-step { text-align: center; flex: 1; position: relative; }
        .track-step .circle { width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto; font-size: 1.2rem; transition: all 0.3s; }
        .track-step .circle.done { background: #22c55e; color: white; }
        .track-step .circle.pending { background: #e5e7eb; color: #9ca3af; }
        .track-step .circle.active { background: #3b82f6; color: white; animation: pulse 1.5s infinite; }
        .track-step .circle.cancelled { background: #ef4444; color: white; }
        .track-line { height: 4px; flex: 1; margin-top: -30px; align-self: center; }
        .track-line.done { background: #22c55e; }
        .track-line.pending { background: #e5e7eb; }
        @@keyframes pulse { 0%,100% { transform:scale(1); } 50% { transform:scale(1.1); } }
    </style>
</head>
<body>
    <nav class="top-bar py-3 px-3 mb-4">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center text-white">
                    <i class="bi bi-droplet-fill fs-4 me-2"></i>
                    <h5 class="mb-0 fw-bold">Raj Dairy - Order Tracking</h5>
                </div>
                <a href="/Public/Login" class="btn btn-outline-light btn-sm">Partner Login</a>
            </div>
        </div>
    </nav>

    <div class="container pb-5" style="max-width:600px;">
        <!-- Search -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4 text-center">
                <i class="bi bi-truck fs-1 text-primary d-block mb-2"></i>
                <h4 class="fw-bold">Order Track Karein</h4>
                <p class="text-muted small">Apna Order Number dalein aur status dekhein</p>
                <form method="get" class="mt-3">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text" style="border-radius:12px 0 0 12px;"><i class="bi bi-search"></i></span>
                        <input type="text" name="orderNumber" class="form-control fw-bold" value="@Context.Request.Query["orderNumber"]"
                               placeholder="e.g. ORD202604070001" style="border-radius:0 12px 12px 0;letter-spacing:1px;" autofocus>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100 mt-3" style="border-radius:12px;">
                        <i class="bi bi-search me-2"></i>Track Order
                    </button>
                </form>
            </div>
        </div>

        @if (Context.Request.Query.ContainsKey("orderNumber") && Model == null)
        {
            <div class="alert alert-danger text-center">
                <i class="bi bi-exclamation-triangle me-2"></i>Order nahi mila! Number check karein.
            </div>
        }

        @if (Model != null)
        {
            var stepsDone = Model.Status switch
            {
                DairyProductApp.Models.OrderStatus.Pending => 1,
                DairyProductApp.Models.OrderStatus.Confirmed => 2,
                DairyProductApp.Models.OrderStatus.OutForDelivery => 3,
                DairyProductApp.Models.OrderStatus.Delivered => 4,
                _ => 0
            };
            var isCancelled = Model.Status == DairyProductApp.Models.OrderStatus.Cancelled;

            <!-- Order Details -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h5 class="fw-bold mb-1">@Model.OrderNumber</h5>
                            <small class="text-muted">@Model.OrderDate.ToString("dd MMM yyyy")</small>
                        </div>
                        @{
                            var statusColor = Model.Status switch
                            {
                                DairyProductApp.Models.OrderStatus.Pending => "warning",
                                DairyProductApp.Models.OrderStatus.Confirmed => "primary",
                                DairyProductApp.Models.OrderStatus.OutForDelivery => "info",
                                DairyProductApp.Models.OrderStatus.Delivered => "success",
                                DairyProductApp.Models.OrderStatus.Cancelled => "danger",
                                _ => "secondary"
                            };
                        }
                        <span class="badge bg-@statusColor fs-6 px-3 py-2">@Model.Status</span>
                    </div>

                    <!-- Product Info -->
                    <div class="card bg-light border-0 mb-3">
                        <div class="card-body py-3">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <span class="fw-bold">@Model.ProductName</span>
                                    <small class="text-muted d-block">@Model.Quantity @Model.Unit &#64; &#8377;@Model.Rate</small>
                                </div>
                                <h4 class="fw-bold text-success mb-0">&#8377;@Model.TotalAmount.ToString("N0")</h4>
                            </div>
                        </div>
                    </div>

                    <!-- Tracking Steps -->
                    @if (!isCancelled)
                    {
                        <h6 class="fw-bold mb-3"><i class="bi bi-geo-alt me-1"></i>Delivery Status</h6>
                        <div class="d-flex align-items-start mb-3">
                            <div class="track-step">
                                <div class="circle @(stepsDone >= 1 ? "done" : "pending")"><i class="bi bi-clock"></i></div>
                                <small class="d-block mt-2 @(stepsDone >= 1 ? "fw-bold" : "text-muted")">Pending</small>
                            </div>
                            <div class="track-line @(stepsDone >= 2 ? "done" : "pending")"></div>
                            <div class="track-step">
                                <div class="circle @(stepsDone >= 2 ? "done" : (stepsDone == 1 ? "active" : "pending"))"><i class="bi bi-check-circle"></i></div>
                                <small class="d-block mt-2 @(stepsDone >= 2 ? "fw-bold" : "text-muted")">Confirmed</small>
                            </div>
                            <div class="track-line @(stepsDone >= 3 ? "done" : "pending")"></div>
                            <div class="track-step">
                                <div class="circle @(stepsDone >= 3 ? "done" : (stepsDone == 2 ? "active" : "pending"))"><i class="bi bi-truck"></i></div>
                                <small class="d-block mt-2 @(stepsDone >= 3 ? "fw-bold" : "text-muted")">Out for Delivery</small>
                            </div>
                            <div class="track-line @(stepsDone >= 4 ? "done" : "pending")"></div>
                            <div class="track-step">
                                <div class="circle @(stepsDone >= 4 ? "done" : (stepsDone == 3 ? "active" : "pending"))"><i class="bi bi-check2-all"></i></div>
                                <small class="d-block mt-2 @(stepsDone >= 4 ? "fw-bold" : "text-muted")">Delivered</small>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger text-center">
                            <i class="bi bi-x-circle fs-3 d-block mb-1"></i>
                            <strong>Order Cancelled</strong>
                        </div>
                    }

                    <!-- Details -->
                    <div class="row g-2 mt-2">
                        <div class="col-6">
                            <small class="text-muted d-block">Delivery Date</small>
                            <span class="fw-bold">@Model.DeliveryDate.ToString("dd MMM yyyy")</span>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Delivery Slot</small>
                            <span class="fw-bold">@Model.DeliverySlot</span>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Payment</small>
                            <span class="badge bg-@(Model.PaymentStatus == DairyProductApp.Models.PaymentStatus.Paid ? "success" : "danger")">@Model.PaymentStatus</span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.DeliveryAddress))
                        {
                            <div class="col-6">
                                <small class="text-muted d-block">Address</small>
                                <span>@Model.DeliveryAddress</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <div class="text-center">
            <a href="/Public/Login" class="text-primary small text-decoration-none">
                <i class="bi bi-person-badge me-1"></i>Partner Login - Poora Hisab Dekhein
            </a>
        </div>
    </div>
</body>
</html>
