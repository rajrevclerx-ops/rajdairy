<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Raj Dairy</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DairyProductApp.styles.css" asp-append-version="true" />
    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0f172a" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Raj Dairy" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
</head>
<body>
    <!-- Top Navbar -->
    <nav class="navbar navbar-dark shadow-sm fixed-top top-navbar">
        <div class="container-fluid">
            <div class="d-flex align-items-center">
                <button class="btn btn-link text-white fs-5 me-2 d-lg-none sidebar-toggle" type="button" onclick="document.getElementById('sidebar').classList.toggle('show')">
                    <i class="bi bi-list"></i>
                </button>
                <a class="navbar-brand fw-bold d-flex align-items-center mb-0" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-droplet-fill me-2 fs-4"></i>
                    <span>Raj Dairy</span>
                    <span class="badge bg-primary bg-opacity-25 text-white ms-2" style="font-size:0.55rem;letter-spacing:1px;padding:3px 8px;border-radius:50px;">PRO</span>
                </a>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="text-white-50 small d-none d-md-inline me-2">
                    <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("dd MMM yyyy, dddd")
                </span>

                <!-- Notification Bell -->
                <div class="dropdown">
                    <button class="notification-bell" type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" id="notifBell">
                        <i class="bi bi-bell-fill"></i>
                        <span class="notification-badge" id="notifCount" style="display:none;">0</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end notification-dropdown p-0">
                        <div class="dropdown-header d-flex justify-content-between align-items-center">
                            <h6 class="fw-bold mb-0">Notifications</h6>
                            <a asp-controller="Notification" asp-action="Index" class="text-primary small text-decoration-none">View All</a>
                        </div>
                        <div id="notifList">
                            <div class="text-center py-4 text-muted small">
                                <i class="bi bi-bell-slash d-block mb-1" style="font-size:1.5rem;"></i>
                                Loading...
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Admin Dropdown -->
                <!-- Dark Mode Toggle -->
                <button class="btn btn-outline-light btn-sm" id="darkModeToggle" title="Dark Mode" style="border-radius:50%;width:34px;height:34px;padding:0;">
                    <i class="bi bi-moon-fill" id="darkModeIcon"></i>
                </button>

                <div class="dropdown">
                    <a class="btn btn-outline-light btn-sm dropdown-toggle d-flex align-items-center gap-1" href="#" role="button" data-bs-toggle="dropdown" style="border-radius:50px;padding:4px 14px;">
                        <div id="navAvatar" style="width:24px;height:24px;border-radius:50%;background:linear-gradient(135deg,#2563eb,#7c3aed);display:flex;align-items:center;justify-content:center;">
                            <i class="bi bi-person-fill" style="font-size:0.7rem;"></i>
                        </div>
                        <span class="d-none d-md-inline">Admin</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Profile"><i class="bi bi-person me-2"></i>Profile</a></li>
                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Settings"><i class="bi bi-gear me-2"></i>Settings</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword"><i class="bi bi-key me-2"></i>Change Password</a></li>
                        <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <div class="d-flex">
        <!-- Sidebar -->
        <nav id="sidebar" class="sidebar">
            <div class="sidebar-header">
                <div class="text-center py-3">
                    <a asp-controller="Admin" asp-action="Profile" class="text-decoration-none">
                        <div id="sidebarAvatar" class="admin-avatar">
                            <i class="bi bi-person-fill"></i>
                        </div>
                    </a>
                    <h6 class="fw-bold text-white mt-2 mb-0">Admin Panel</h6>
                    <small class="text-white-50">Raj Dairy Management</small>
                </div>
            </div>
            <hr class="sidebar-divider">

            <ul class="nav flex-column sidebar-nav">
                <li class="nav-item sidebar-heading">
                    <span>MAIN MENU</span>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Analytics" asp-action="Index">
                        <i class="bi bi-graph-up-arrow"></i>
                        <span>Analytics</span>
                        <span class="nav-badge bg-primary text-white">NEW</span>
                    </a>
                </li>

                <li class="nav-item sidebar-heading">
                    <span>ORDERS & SUBSCRIPTIONS</span>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Order" asp-action="Index">
                        <i class="bi bi-bag-check-fill"></i>
                        <span>Orders</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Order" asp-action="Create">
                        <i class="bi bi-bag-plus"></i>
                        <span>New Order</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Subscription" asp-action="Index">
                        <i class="bi bi-calendar-check"></i>
                        <span>Subscriptions</span>
                    </a>
                </li>

                <li class="nav-item sidebar-heading">
                    <span>MILK MANAGEMENT</span>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="MilkCollection" asp-action="Index">
                        <i class="bi bi-cup-hot-fill"></i>
                        <span>Milk Collections</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="MilkCollection" asp-action="QuickEntry">
                        <i class="bi bi-lightning-charge-fill"></i>
                        <span>Quick Entry</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="MilkRate" asp-action="Index">
                        <i class="bi bi-currency-rupee"></i>
                        <span>Rate Chart</span>
                    </a>
                </li>

                <li class="nav-item sidebar-heading">
                    <span>PRODUCTS</span>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="DairyProduct" asp-action="Index">
                        <i class="bi bi-box-seam-fill"></i>
                        <span>All Products</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="DairyProduct" asp-action="Create">
                        <i class="bi bi-plus-circle"></i>
                        <span>Add Product</span>
                    </a>
                </li>

                <li class="nav-item sidebar-heading">
                    <span>GHEE PRODUCTION</span>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="GheeProduct" asp-action="Index">
                        <i class="bi bi-fire"></i>
                        <span>Ghee Batches</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="GheeProduct" asp-action="Create">
                        <i class="bi bi-plus-circle"></i>
                        <span>New Batch</span>
                    </a>
                </li>

                <li class="nav-item sidebar-heading">
                    <span>PARTNERS & HISAB</span>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Partner" asp-action="Index">
                        <i class="bi bi-people-fill"></i>
                        <span>All Partners</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Partner" asp-action="Create">
                        <i class="bi bi-person-plus"></i>
                        <span>Add Partner</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Transaction" asp-action="Index">
                        <i class="bi bi-journal-text"></i>
                        <span>All Transactions</span>
                    </a>
                </li>

                <li class="nav-item sidebar-heading">
                    <span>TOOLS</span>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Tools" asp-action="Attendance">
                        <i class="bi bi-clipboard-check"></i>
                        <span>Attendance</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Tools" asp-action="RateCalculator">
                        <i class="bi bi-calculator"></i>
                        <span>Rate Calculator</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Tools" asp-action="Leaderboard">
                        <i class="bi bi-trophy"></i>
                        <span>Leaderboard</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Tools" asp-action="DeliveryRoute">
                        <i class="bi bi-truck"></i>
                        <span>Delivery Route</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Broadcast" asp-action="Index">
                        <i class="bi bi-whatsapp"></i>
                        <span>Broadcast</span>
                    </a>
                </li>

                <li class="nav-item sidebar-heading">
                    <span>FINANCE & REPORTS</span>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Payment" asp-action="BulkPayment">
                        <i class="bi bi-cash-coin"></i>
                        <span>Farmer Payments</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Expense" asp-action="Index">
                        <i class="bi bi-wallet2"></i>
                        <span>Expenses</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Expense" asp-action="ProfitLoss">
                        <i class="bi bi-graph-up-arrow"></i>
                        <span>Profit & Loss</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Report" asp-action="Daily">
                        <i class="bi bi-calendar-day"></i>
                        <span>Daily Report</span>
                    </a>
                </li>

                <li class="nav-item sidebar-heading">
                    <span>ADMIN</span>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Notification" asp-action="Index">
                        <i class="bi bi-bell"></i>
                        <span>Notifications</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Admin" asp-action="Profile">
                        <i class="bi bi-person-circle"></i>
                        <span>Profile</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Admin" asp-action="Settings">
                        <i class="bi bi-gear"></i>
                        <span>Settings</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar-footer">
                <div class="small text-white-50 text-center py-2">
                    <i class="bi bi-droplet-fill me-1"></i>Raj Dairy v2.0 Pro
                </div>
            </div>
        </nav>

        <!-- Main Content -->
        <div class="main-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <main role="main" class="pb-3">
                @RenderBody()
            </main>

            <footer class="content-footer">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted small">&copy; @DateTime.Now.Year Raj Dairy - All Rights Reserved</span>
                    <span class="text-muted small">
                        <i class="bi bi-droplet-fill text-primary me-1"></i>Admin Panel v2.0 Pro
                    </span>
                </div>
            </footer>
        </div>
    </div>

    <!-- Overlay for mobile sidebar -->
    <div class="sidebar-overlay" onclick="document.getElementById('sidebar').classList.remove('show')"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Load profile photo from Google Sheets
        $(function () {
            $.get('@Url.Action("GetPhoto", "Admin")', function (data) {
                if (data.photo) {
                    $('#sidebarAvatar').replaceWith(
                        '<img src="' + data.photo + '" alt="Admin" class="rounded-3 shadow" style="width:64px;height:64px;object-fit:cover;border:3px solid rgba(255,255,255,0.15);" />'
                    );
                    $('#navAvatar').replaceWith(
                        '<img src="' + data.photo + '" alt="" style="width:24px;height:24px;border-radius:50%;object-fit:cover;" />'
                    );
                }
            });
        });

        // Highlight active sidebar link
        $(function () {
            var currentPath = window.location.pathname.toLowerCase();
            $('.sidebar-nav .nav-link').each(function () {
                var href = $(this).attr('href');
                if (href && currentPath === href.toLowerCase()) {
                    $(this).addClass('active');
                } else if (href && currentPath.startsWith(href.toLowerCase()) && href !== '/') {
                    $(this).addClass('active');
                }
            });
            if (currentPath === '/' || currentPath === '/home' || currentPath === '/home/index') {
                $('.sidebar-nav .nav-link').first().addClass('active');
            }
        });

        // Load notifications
        function loadNotifications() {
            $.get('@Url.Action("GetUnreadCount", "Notification")', function (data) {
                if (data.unreadCount > 0) {
                    $('#notifCount').text(data.unreadCount).show();
                    $('#notifBell').addClass('has-unread');
                } else {
                    $('#notifCount').hide();
                    $('#notifBell').removeClass('has-unread');
                }

                var html = '';
                if (data.notifications && data.notifications.length > 0) {
                    data.notifications.forEach(function (n) {
                        var typeColors = {
                            'Success': 'bg-success bg-opacity-10 text-success',
                            'Warning': 'bg-warning bg-opacity-10 text-warning',
                            'Danger': 'bg-danger bg-opacity-10 text-danger',
                            'Order': 'bg-primary bg-opacity-10 text-primary',
                            'Payment': 'bg-success bg-opacity-10 text-success',
                            'Subscription': 'bg-info bg-opacity-10 text-info',
                            'Stock': 'bg-warning bg-opacity-10 text-warning',
                            'Info': 'bg-primary bg-opacity-10 text-primary'
                        };
                        var colorClass = typeColors[n.type] || typeColors['Info'];
                        html += '<div class="notification-item ' + (n.isRead ? '' : 'unread') + '">';
                        html += '<div class="notification-icon ' + colorClass + '"><i class="bi ' + (n.icon || 'bi-info-circle') + '"></i></div>';
                        html += '<div class="flex-grow-1">';
                        html += '<h6 class="fw-bold mb-0" style="font-size:0.82rem;">' + n.title + '</h6>';
                        html += '<p class="text-muted mb-0" style="font-size:0.75rem;">' + n.message + '</p>';
                        html += '<small class="text-muted">' + n.time + '</small>';
                        html += '</div></div>';
                    });
                    html += '<div class="text-center py-2 border-top">';
                    html += '<a href="@Url.Action("Index", "Notification")" class="text-primary small text-decoration-none fw-semibold">Sab Notifications Dekhein</a>';
                    html += '</div>';
                } else {
                    html = '<div class="text-center py-4 text-muted small">';
                    html += '<i class="bi bi-bell-slash d-block mb-1" style="font-size:1.5rem;"></i>Koi notification nahi hai</div>';
                }
                $('#notifList').html(html);
            }).fail(function() {
                $('#notifList').html('<div class="text-center py-3 text-muted small">Notifications load nahi ho payi</div>');
            });
        }

        // Load notifications on page load and refresh every 30 seconds
        $(function () {
            loadNotifications();
            setInterval(loadNotifications, 30000);
        });

        // Register PWA Service Worker
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js');
        }

        // Dark Mode
        $(function () {
            var isDark = localStorage.getItem('rajdairy-dark') === 'true';
            if (isDark) enableDark();

            $('#darkModeToggle').click(function () {
                isDark = !isDark;
                localStorage.setItem('rajdairy-dark', isDark);
                if (isDark) enableDark(); else disableDark();
            });

            function enableDark() {
                $('body').addClass('dark-mode');
                $('#darkModeIcon').removeClass('bi-moon-fill').addClass('bi-sun-fill');
            }
            function disableDark() {
                $('body').removeClass('dark-mode');
                $('#darkModeIcon').removeClass('bi-sun-fill').addClass('bi-moon-fill');
            }
        });
    </script>
</body>
</html>
