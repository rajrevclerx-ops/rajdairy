<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Raj Dairy</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DairyProductApp.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- Top Navbar -->
    <nav class="navbar navbar-dark shadow-sm fixed-top top-navbar">
        <div class="container-fluid">
            <div class="d-flex align-items-center">
                <button class="btn btn-link text-white fs-5 me-2 d-lg-none sidebar-toggle" type="button" onclick="document.getElementById('sidebar').classList.toggle('show')">
                    <i class="bi bi-list"></i>
                </button>
                <a class="navbar-brand fw-bold d-flex align-items-center mb-0" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-droplet-fill me-2 fs-4"></i>
                    <span>Raj Dairy</span>
                </a>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="text-white-50 small d-none d-md-inline">
                    <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("dd MMM yyyy, dddd")
                </span>
                <div class="dropdown">
                    <a class="btn btn-outline-light btn-sm dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-1"></i>Admin
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Profile"><i class="bi bi-person me-2"></i>Profile</a></li>
                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Settings"><i class="bi bi-gear me-2"></i>Settings</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Admin" asp-action="Logout" method="post" class="px-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Logout</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <div class="d-flex">
        <!-- Sidebar -->
        <nav id="sidebar" class="sidebar">
            <div class="sidebar-header">
                <div class="text-center py-3">
                    <a asp-controller="Admin" asp-action="Profile" class="text-decoration-none">
                        <div id="sidebarAvatar" class="admin-avatar">
                            <i class="bi bi-person-fill"></i>
                        </div>
                    </a>
                    <h6 class="fw-bold text-white mt-2 mb-0">Admin Panel</h6>
                    <small class="text-white-50">Raj Dairy Management</small>
                </div>
            </div>
            <hr class="sidebar-divider">

            <ul class="nav flex-column sidebar-nav">
                <li class="nav-item sidebar-heading">
                    <span>MAIN MENU</span>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>
                    </a>
                </li>

                <li class="nav-item sidebar-heading">
                    <span>MILK MANAGEMENT</span>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="MilkCollection" asp-action="Index">
                        <i class="bi bi-cup-hot-fill"></i>
                        <span>Milk Collections</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="MilkCollection" asp-action="Create">
                        <i class="bi bi-plus-circle"></i>
                        <span>New Collection</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="MilkRate" asp-action="Index">
                        <i class="bi bi-currency-rupee"></i>
                        <span>Rate Chart</span>
                    </a>
                </li>

                <li class="nav-item sidebar-heading">
                    <span>PRODUCTS</span>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="DairyProduct" asp-action="Index">
                        <i class="bi bi-box-seam-fill"></i>
                        <span>All Products</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="DairyProduct" asp-action="Create">
                        <i class="bi bi-plus-circle"></i>
                        <span>Add Product</span>
                    </a>
                </li>

                <li class="nav-item sidebar-heading">
                    <span>GHEE PRODUCTION</span>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="GheeProduct" asp-action="Index">
                        <i class="bi bi-fire"></i>
                        <span>Ghee Batches</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="GheeProduct" asp-action="Create">
                        <i class="bi bi-plus-circle"></i>
                        <span>New Batch</span>
                    </a>
                </li>

                <li class="nav-item sidebar-heading">
                    <span>ADMIN</span>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Admin" asp-action="Profile">
                        <i class="bi bi-person-circle"></i>
                        <span>Profile</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Admin" asp-action="Settings">
                        <i class="bi bi-gear"></i>
                        <span>Settings</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar-footer">
                <div class="small text-white-50 text-center py-2">
                    <i class="bi bi-droplet-fill me-1"></i>Raj Dairy v1.0
                </div>
            </div>
        </nav>

        <!-- Main Content -->
        <div class="main-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <main role="main" class="pb-3">
                @RenderBody()
            </main>

            <footer class="content-footer">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted small">&copy; @DateTime.Now.Year Raj Dairy - All Rights Reserved</span>
                    <span class="text-muted small"><i class="bi bi-droplet-fill text-primary me-1"></i>Admin Panel v1.0</span>
                </div>
            </footer>
        </div>
    </div>

    <!-- Overlay for mobile sidebar -->
    <div class="sidebar-overlay" onclick="document.getElementById('sidebar').classList.remove('show')"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Load profile photo from Google Sheets
        $(function () {
            $.get('@Url.Action("GetPhoto", "Admin")', function (data) {
                if (data.photo) {
                    $('#sidebarAvatar').replaceWith(
                        '<img src="' + data.photo + '" alt="Admin" class="rounded-circle shadow" style="width:65px;height:65px;object-fit:cover;border:3px solid rgba(255,255,255,0.3);" />'
                    );
                }
            });
        });

        // Highlight active sidebar link
        $(function () {
            var currentPath = window.location.pathname.toLowerCase();
            $('.sidebar-nav .nav-link').each(function () {
                var href = $(this).attr('href');
                if (href && currentPath === href.toLowerCase()) {
                    $(this).addClass('active');
                } else if (href && currentPath.startsWith(href.toLowerCase()) && href !== '/') {
                    $(this).addClass('active');
                }
            });
            if (currentPath === '/' || currentPath === '/home' || currentPath === '/home/index') {
                $('.sidebar-nav .nav-link').first().addClass('active');
            }
        });
    </script>
</body>
</html>
