@model DairyProductApp.Models.Subscription
@{ ViewData["Title"] = "Subscription Details"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-primary mb-0"><i class="bi bi-calendar-check me-2"></i>Subscription Details</h3>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h4 class="fw-bold mb-1">@Model.PartnerName</h4>
                        <span class="badge bg-info">@Model.Product</span>
                        <span class="badge bg-secondary">@Model.Frequency</span>
                    </div>
                    @{
                        var subColor = Model.Status == DairyProductApp.Models.SubscriptionStatus.Active ? "success" :
                                       Model.Status == DairyProductApp.Models.SubscriptionStatus.Paused ? "warning" : "secondary";
                    }
                    <span class="badge bg-@subColor fs-6 px-3 py-2">@Model.Status</span>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="card bg-primary bg-opacity-10 border-0 text-center">
                            <div class="card-body">
                                <small class="text-muted">Daily Quantity</small>
                                <h4 class="fw-bold text-primary mb-0">@Model.DailyQuantity @Model.Unit</h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card bg-success bg-opacity-10 border-0 text-center">
                            <div class="card-body">
                                <small class="text-muted">Rate Per Unit</small>
                                <h4 class="fw-bold text-success mb-0">&#8377;@Model.RatePerUnit</h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <p class="mb-1"><strong>Start Date:</strong></p>
                        <p>@Model.StartDate.ToString("dd MMM yyyy")</p>
                    </div>
                    <div class="col-md-4">
                        <p class="mb-1"><strong>End Date:</strong></p>
                        <p>@(Model.EndDate?.ToString("dd MMM yyyy") ?? "Ongoing")</p>
                    </div>
                    <div class="col-md-4">
                        <p class="mb-1"><strong>Delivery Slot:</strong></p>
                        <p>@Model.DeliverySlot</p>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-1"><strong>Monthly Estimate:</strong></p>
                        <h5 class="text-success fw-bold">&#8377;@Model.MonthlyEstimate.ToString("N0")</h5>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.DeliveryAddress))
                    {
                        <div class="col-12">
                            <p><i class="bi bi-geo-alt me-1"></i><strong>Address:</strong> @Model.DeliveryAddress</p>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <div class="col-12">
                            <p><i class="bi bi-chat-text me-1"></i><strong>Notes:</strong> @Model.Notes</p>
                        </div>
                    }
                </div>

                <div class="mt-4 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil me-1"></i>Edit</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i>Delete</a>
                </div>
            </div>
        </div>
    </div>
</div>
