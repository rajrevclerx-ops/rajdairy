@model DairyProductApp.Models.Subscription
@{
    ViewData["Title"] = "Edit Subscription";
    var partners = ViewBag.Partners as List<DairyProductApp.Models.Partner> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4 page-header">
    <div>
        <h3 class="fw-bold mb-1"><i class="bi bi-pencil-square me-2 text-primary"></i>Edit Subscription</h3>
        <p class="text-muted mb-0 small">@Model.PartnerName ki subscription update karein</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="PartnerId" class="form-label">Partner</label>
                            <select asp-for="PartnerId" class="form-select">
                                @foreach (var p in partners.Where(p => p.IsActive))
                                {
                                    <option value="@p.Id">@p.Name (@p.Type)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Product" class="form-label">Product</label>
                            <select asp-for="Product" asp-items="Html.GetEnumSelectList<DairyProductApp.Models.SubscriptionProduct>()" class="form-select"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DailyQuantity" class="form-label">Daily Quantity</label>
                            <input asp-for="DailyQuantity" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Unit" class="form-label">Unit</label>
                            <select asp-for="Unit" class="form-select">
                                <option>Liter</option><option>Kg</option><option>Packet</option><option>Piece</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="RatePerUnit" class="form-label">Rate Per Unit (&#8377;)</label>
                            <input asp-for="RatePerUnit" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Frequency" class="form-label">Frequency</label>
                            <select asp-for="Frequency" asp-items="Html.GetEnumSelectList<DairyProductApp.Models.DeliveryFrequency>()" class="form-select"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DeliverySlot" class="form-label">Delivery Slot</label>
                            <select asp-for="DeliverySlot" asp-items="Html.GetEnumSelectList<DairyProductApp.Models.DeliverySlot>()" class="form-select"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label">Status</label>
                            <select asp-for="Status" asp-items="Html.GetEnumSelectList<DairyProductApp.Models.SubscriptionStatus>()" class="form-select"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label">Start Date</label>
                            <input asp-for="StartDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label">End Date</label>
                            <input asp-for="EndDate" type="date" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="DeliveryAddress" class="form-label">Delivery Address</label>
                            <textarea asp-for="DeliveryAddress" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-12">
                            <label asp-for="Notes" class="form-label">Notes</label>
                            <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                            <i class="bi bi-check-circle me-1"></i>Update Subscription
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
