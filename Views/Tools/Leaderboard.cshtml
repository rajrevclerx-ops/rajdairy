@model List<DairyProductApp.Controllers.FarmerRankViewModel>
@{ ViewData["Title"] = "Farmer Leaderboard"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-trophy-fill me-2 text-warning"></i>Farmer Leaderboard</h3>
        <p class="text-muted mb-0 small">@ViewBag.MonthName - Top performing farmers</p>
    </div>
    <form method="get" class="d-flex gap-2">
        <select name="month" class="form-select form-select-sm" style="width:auto;">
            @for (int m = 1; m <= 12; m++)
            {
                <option value="@m" selected="@(m == (int)ViewBag.Month)">@(new DateTime(2026, m, 1).ToString("MMM"))</option>
            }
        </select>
        <button class="btn btn-sm btn-primary" style="border-radius:8px;"><i class="bi bi-search"></i></button>
    </form>
</div>

<!-- Top 3 Podium -->
@if (Model.Count >= 3)
{
    <div class="row g-3 mb-4 justify-content-center">
        <!-- 2nd Place -->
        <div class="col-md-3 text-center order-md-1 order-2">
            <div class="card border-0 shadow-sm" style="border-radius:16px;border-top:4px solid #94a3b8 !important;">
                <div class="card-body py-4">
                    <div class="mx-auto mb-2" style="width:50px;height:50px;border-radius:50%;background:#94a3b8;display:flex;align-items:center;justify-content:center;color:white;font-size:1.5rem;font-weight:800;">2</div>
                    <h6 class="fw-bold mb-1">@Model[1].FarmerName</h6>
                    <span class="text-primary fw-bold">@Model[1].TotalMilk.ToString("F0") L</span>
                    <small class="text-muted d-block">&#8377;@Model[1].TotalAmount.ToString("N0")</small>
                </div>
            </div>
        </div>
        <!-- 1st Place -->
        <div class="col-md-4 text-center order-md-2 order-1">
            <div class="card border-0 shadow-sm" style="border-radius:16px;border-top:4px solid #f59e0b !important;transform:scale(1.05);">
                <div class="card-body py-4">
                    <div class="mx-auto mb-2" style="width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,#f59e0b,#ef4444);display:flex;align-items:center;justify-content:center;color:white;font-size:1.8rem;font-weight:800;">
                        <i class="bi bi-trophy-fill"></i>
                    </div>
                    <h5 class="fw-bold mb-1">@Model[0].FarmerName</h5>
                    <span class="text-primary fw-bold fs-5">@Model[0].TotalMilk.ToString("F0") L</span>
                    <small class="text-success d-block fw-bold">&#8377;@Model[0].TotalAmount.ToString("N0")</small>
                    <small class="text-muted">Avg Fat: @Model[0].AvgFat.ToString("F1")% | @Model[0].TotalDays days</small>
                </div>
            </div>
        </div>
        <!-- 3rd Place -->
        <div class="col-md-3 text-center order-md-3 order-3">
            <div class="card border-0 shadow-sm" style="border-radius:16px;border-top:4px solid #b45309 !important;">
                <div class="card-body py-4">
                    <div class="mx-auto mb-2" style="width:50px;height:50px;border-radius:50%;background:#b45309;display:flex;align-items:center;justify-content:center;color:white;font-size:1.5rem;font-weight:800;">3</div>
                    <h6 class="fw-bold mb-1">@Model[2].FarmerName</h6>
                    <span class="text-primary fw-bold">@Model[2].TotalMilk.ToString("F0") L</span>
                    <small class="text-muted d-block">&#8377;@Model[2].TotalAmount.ToString("N0")</small>
                </div>
            </div>
        </div>
    </div>
}

<!-- Full Ranking Table -->
<div class="card border-0 shadow-sm" style="border-radius:16px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Rank</th>
                        <th>Farmer</th>
                        <th>Total Milk</th>
                        <th>Amount</th>
                        <th>Avg Fat%</th>
                        <th>Avg SNF%</th>
                        <th>Days</th>
                        <th>Milk Progress</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        int rank = 1;
                        var maxMilk = Model.Max(f => f.TotalMilk);
                        @foreach (var f in Model)
                        {
                            var medalColor = rank switch { 1 => "#f59e0b", 2 => "#94a3b8", 3 => "#b45309", _ => "" };
                            var percent = maxMilk > 0 ? (f.TotalMilk / maxMilk * 100) : 0;
                            <tr>
                                <td>
                                    @if (rank <= 3)
                                    {
                                        <span class="badge" style="background:@medalColor;width:28px;height:28px;display:inline-flex;align-items:center;justify-content:center;border-radius:50%;font-size:0.8rem;">@rank</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fw-bold">#@rank</span>
                                    }
                                </td>
                                <td class="fw-bold">@f.FarmerName</td>
                                <td class="fw-bold text-primary">@f.TotalMilk.ToString("F0") L</td>
                                <td class="text-success fw-bold">&#8377;@f.TotalAmount.ToString("N0")</td>
                                <td><span class="badge bg-danger bg-opacity-75">@f.AvgFat.ToString("F1")%</span></td>
                                <td><span class="badge bg-success bg-opacity-75">@f.AvgSNF.ToString("F1")%</span></td>
                                <td>@f.TotalDays</td>
                                <td style="min-width:150px;">
                                    <div class="progress" style="height:8px;border-radius:4px;">
                                        <div class="progress-bar @(rank == 1 ? "bg-warning" : "bg-primary")" style="width:@percent.ToString("F0")%;border-radius:4px;"></div>
                                    </div>
                                </td>
                            </tr>
                            rank++;
                        }
                    }
                    else
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">Is mahine koi data nahi hai</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
